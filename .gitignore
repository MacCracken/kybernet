# Build output
/build/
/rust-old/target/

# Resolved dependencies — populated by `cyrius deps` from `cyrius.cyml`
# and pinned by sha256 in `cyrius.lock`. Match the AGNOS-wide convention
# (agnosys / agnostik / libro / argonaut all gitignore lib/).
/lib/

# QEMU harness build artifacts — `qemu/build-initramfs.sh` stages a
# tree under `qemu/initramfs/` and bundles `initramfs.cpio.gz`. The
# checked-in shape lives in `qemu/build-initramfs.sh` only; the
# artifacts regenerate from it. Matches argonaut's qemu/ convention.
/qemu/initramfs/
/qemu/initramfs.cpio.gz

