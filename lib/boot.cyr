# boot.cyr — Boot sequence construction
# Builds ordered list of BootSteps for each BootMode.
# Ported from rust-old/src/boot.rs

fn build_boot_sequence(mode) {
    var steps = vec_new();

    # Common early stages
    var s0 = str_from("Mount essential filesystems (proc, sys, dev, tmp)");
    vec_push(steps, boot_step_new(STAGE_MOUNT_FS, s0, 1, 2000));
    vec_push(steps, boot_step_new(STAGE_DEVICE_MGR,
    str_from("Start udev device manager"), 1, 3000));
    vec_push(steps, boot_step_new(STAGE_VERIFY_ROOTFS,
    str_from("Verify rootfs integrity via dm-verity"), 1, 5000));
    var s3 = str_from("Initialize Landlock, seccomp, and MAC policies");
    vec_push(steps, boot_step_new(STAGE_SECURITY, s3, 1, 2000));

    # Recovery: early stages only, then emergency shell
    if (mode == BOOT_RECOVERY) {
        var sr = str_from("Recovery boot complete — dropping to emergency shell");
        vec_push(steps, boot_step_new(STAGE_BOOT_COMPLETE, sr, 1, 500));
        return steps;
    }

    # Edge: dm-verity, TPM, then straight to agent-runtime
    if (mode == BOOT_EDGE) {
        var se = str_from("Start daimon (agent-runtime) in edge mode on port 8090");
        vec_push(steps, boot_step_new(STAGE_AGENT_RUNTIME, se, 1, 3000));
        vec_push(steps, boot_step_new(STAGE_BOOT_COMPLETE, str_from("Edge boot complete — agent ready"), 1, 500));
        return steps;
    }

    # Server and Desktop get database services
    if (mode == BOOT_SERVER || mode == BOOT_DESKTOP) {
        var sd = str_from("Start PostgreSQL and Redis database services");
        vec_push(steps, boot_step_new(STAGE_DATABASE, sd, 1, 15000));
    }

    # Agent runtime (all non-recovery, non-edge modes)
    vec_push(steps, boot_step_new(STAGE_AGENT_RUNTIME, str_from("Start daimon (agent-runtime) on port 8090"), 1, 5000));

    # Server and Desktop get LLM gateway + model services
    if (mode == BOOT_SERVER || mode == BOOT_DESKTOP) {
        vec_push(steps, boot_step_new(STAGE_LLM_GATEWAY, str_from("Start hoosh (llm-gateway) on port 8088"), 0, 5000));
        vec_push(steps, boot_step_new(STAGE_MODEL_SERVICES, str_from("Start Synapse LLM model manager"), 0, 15000));
    }

    # Desktop-only stages
    if (mode == BOOT_DESKTOP) {
        vec_push(steps, boot_step_new(STAGE_COMPOSITOR, str_from("Start aethersafha (Wayland compositor)"), 1, 5000));
        vec_push(steps, boot_step_new(STAGE_SHELL, str_from("Start agnoshi (AI shell)"), 0, 3000));
    }

    # Final stage
    vec_push(steps, boot_step_new(STAGE_BOOT_COMPLETE, str_from("All boot stages finished"), 1, 1000));

    return steps;
}
