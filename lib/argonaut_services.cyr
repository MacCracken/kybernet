# services.cyr — Service management
# Default service definitions, dependency resolution, crash handling.
# Ported from rust-old/src/services.rs

# =========================================================================
# Database service definitions
# =========================================================================

fn postgres_service() {
    var sd = svc_def_new(
    str_from("postgres"),
    str_from("PostgreSQL 17 database server"),
    str_from("/usr/lib/postgresql/17/bin/postgres")
    );
    var args = svc_def_args(sd);
    vec_push(args, str_from("-D"));
    vec_push(args, str_from("/var/lib/postgresql/data"));
    vec_push(args, str_from("-c"));
    vec_push(args, str_from("config_file=/etc/postgresql/postgresql.conf.agnos"));

    map_set(svc_def_env(sd), "PGDATA", str_from("/var/lib/postgresql/data"));

    vec_push(svc_def_modes(sd), BOOT_SERVER);
    vec_push(svc_def_modes(sd), BOOT_DESKTOP);

    store64(sd + 72, health_check_new(HC_TCP_CONNECT, str_from("127.0.0.1"), 5432, 15000, 2000, 3));
    store64(sd + 80, ready_check_new(HC_TCP_CONNECT, str_from("127.0.0.1"), 5432, 10000, 15, 500));

    return sd;
}

fn redis_service() {
    var sd = svc_def_new(
    str_from("redis"),
    str_from("Redis 7 in-memory cache"),
    str_from("/usr/bin/redis-server")
    );
    vec_push(svc_def_args(sd), str_from("/etc/redis/redis.conf"));

    vec_push(svc_def_modes(sd), BOOT_SERVER);
    vec_push(svc_def_modes(sd), BOOT_DESKTOP);

    store64(sd + 56, RESTART_ALWAYS);  # restart_policy
    store64(sd + 72, health_check_new(HC_TCP_CONNECT, str_from("127.0.0.1"), 6379, 10000, 1000, 3));
    store64(sd + 80, ready_check_new(HC_TCP_CONNECT, str_from("127.0.0.1"), 6379, 5000, 10, 200));

    return sd;
}

fn database_services() {
    var svcs = vec_new();
    vec_push(svcs, postgres_service());
    vec_push(svcs, redis_service());
    return svcs;
}

# =========================================================================
# Ifran (LLM inference) service
# =========================================================================

fn ifran_service() {
    var sd = svc_def_new(
    str_from("ifran"),
    str_from("Ifran — local LLM inference, training, and fleet management"),
    str_from("/usr/lib/agnos/ifran")
    );
    var args = svc_def_args(sd);
    vec_push(args, str_from("serve"));
    vec_push(args, str_from("--config"));
    vec_push(args, str_from("/etc/ifran/ifran.toml"));

    var env = svc_def_env(sd);
    map_set(env, "IFRAN_DATA_DIR", str_from("/var/lib/ifran"));
    map_set(env, "IFRAN_MODEL_DIR", str_from("/var/lib/ifran/models"));

    var deps = svc_def_deps(sd);
    vec_push(deps, str_from("daimon"));
    vec_push(deps, str_from("llm-gateway"));

    vec_push(svc_def_modes(sd), BOOT_SERVER);
    vec_push(svc_def_modes(sd), BOOT_DESKTOP);

    store64(sd + 72, health_check_new(HC_HTTP_GET, str_from("http://127.0.0.1:8080/health"), 0, 15000, 3000, 3));
    store64(sd + 80, ready_check_new(HC_TCP_CONNECT, str_from("127.0.0.1"), 8080, 10000, 15, 500));

    return sd;
}

# =========================================================================
# Shruti DAW (optional)
# =========================================================================

fn shruti_service() {
    var sd = svc_def_new(
    str_from("shruti"),
    str_from("Shruti digital audio workstation"),
    str_from("/usr/local/bin/shruti")
    );
    var env = svc_def_env(sd);
    map_set(env, "SHRUTI_DATA_DIR", str_from("/var/lib/shruti"));
    map_set(env, "PIPEWIRE_RUNTIME_DIR", str_from("/run/user/1000"));

    var deps = svc_def_deps(sd);
    vec_push(deps, str_from("daimon"));
    vec_push(deps, str_from("aethersafha"));

    # Not auto-started (required_for_modes is empty)
    store64(sd + 72, health_check_new(HC_PROCESS_ALIVE, 0, 0, 10000, 1000, 3));

    return sd;
}

# =========================================================================
# Default services for a boot mode
# =========================================================================

fn default_services(mode) {
    var services = vec_new();

    # Recovery: no services
    if (mode == BOOT_RECOVERY) { return services; }

    # Edge: agent-runtime only
    if (mode == BOOT_EDGE) {
        var sd = svc_def_new(
        str_from("daimon"),
        str_from("Daimon agent orchestrator (edge mode)"),
        str_from("/usr/lib/agnos/agent_runtime")
        );
        var args = svc_def_args(sd);
        vec_push(args, str_from("--port"));
        vec_push(args, str_from("8090"));
        vec_push(args, str_from("--mode"));
        vec_push(args, str_from("edge"));

        var env = svc_def_env(sd);
        map_set(env, "AGNOS_EDGE_MODE", str_from("1"));
        map_set(env, "AGNOS_READONLY_ROOTFS", str_from("1"));
        map_set(env, "AGNOS_EDGE_LUKS", str_from("1"));

        store64(sd + 56, RESTART_ALWAYS);
        vec_push(svc_def_modes(sd), BOOT_EDGE);
        store64(sd + 72, health_check_new(HC_HTTP_GET, str_from("http://127.0.0.1:8090/v1/health"), 0, 10000, 2000, 3));
        store64(sd + 80, ready_check_new(HC_TCP_CONNECT, str_from("127.0.0.1"), 8090, 3000, 5, 200));

        vec_push(services, sd);
        return services;
    }

    # Database services for Server and Desktop
    if (mode == BOOT_SERVER || mode == BOOT_DESKTOP) {
        var db = database_services();
        for (var i = 0; i < vec_len(db); i = i + 1) {
            vec_push(services, vec_get(db, i));
        }
    }

    # Agent-runtime (always present for non-recovery/edge)
    var daimon = svc_def_new(
    str_from("daimon"),
    str_from("Daimon agent orchestrator"),
    str_from("/usr/lib/agnos/agent_runtime")
    );
    vec_push(svc_def_args(daimon), str_from("--port"));
    vec_push(svc_def_args(daimon), str_from("8090"));
    store64(daimon + 56, RESTART_ALWAYS);

    if (mode == BOOT_SERVER || mode == BOOT_DESKTOP) {
        vec_push(svc_def_deps(daimon), str_from("postgres"));
        vec_push(svc_def_deps(daimon), str_from("redis"));
    }

    vec_push(svc_def_modes(daimon), BOOT_MINIMAL);
    vec_push(svc_def_modes(daimon), BOOT_SERVER);
    vec_push(svc_def_modes(daimon), BOOT_DESKTOP);

    store64(daimon + 72, health_check_new(HC_HTTP_GET, str_from("http://127.0.0.1:8090/v1/health"), 0, 10000, 2000, 3));
    store64(daimon + 80, ready_check_new(HC_TCP_CONNECT, str_from("127.0.0.1"), 8090, 5000, 10, 200));

    vec_push(services, daimon);

    # LLM gateway and ifran for Server/Desktop
    if (mode == BOOT_SERVER || mode == BOOT_DESKTOP) {
        var gw = svc_def_new(
        str_from("llm-gateway"),
        str_from("Hoosh LLM inference gateway"),
        str_from("/usr/lib/agnos/llm_gateway")
        );
        vec_push(svc_def_args(gw), str_from("--port"));
        vec_push(svc_def_args(gw), str_from("8088"));
        vec_push(svc_def_deps(gw), str_from("daimon"));
        vec_push(svc_def_modes(gw), BOOT_SERVER);
        vec_push(svc_def_modes(gw), BOOT_DESKTOP);
        store64(gw + 72, health_check_new(HC_HTTP_GET, str_from("http://127.0.0.1:8088/health"), 0, 15000, 2000, 3));
        store64(gw + 80, ready_check_new(HC_TCP_CONNECT, str_from("127.0.0.1"), 8088, 5000, 10, 200));
        vec_push(services, gw);

        vec_push(services, ifran_service());
    }

    # Desktop-only services
    if (mode == BOOT_DESKTOP) {
        var comp = svc_def_new(
        str_from("aethersafha"),
        str_from("Wayland compositor"),
        str_from("/usr/lib/agnos/aethersafha")
        );
        map_set(svc_def_env(comp), "XDG_SESSION_TYPE", str_from("wayland"));
        vec_push(svc_def_deps(comp), str_from("daimon"));
        vec_push(svc_def_modes(comp), BOOT_DESKTOP);
        store64(comp + 56, RESTART_ALWAYS);
        store64(comp + 72, health_check_new(HC_PROCESS_ALIVE, 0, 0, 5000, 1000, 2));
        vec_push(services, comp);

        var shell = svc_def_new(
        str_from("agnoshi"),
        str_from("AI terminal shell"),
        str_from("/usr/lib/agnos/agnoshi")
        );
        vec_push(svc_def_deps(shell), str_from("daimon"));
        vec_push(svc_def_deps(shell), str_from("aethersafha"));
        vec_push(svc_def_modes(shell), BOOT_DESKTOP);
        store64(shell + 72, health_check_new(HC_PROCESS_ALIVE, 0, 0, 10000, 1000, 3));
        vec_push(services, shell);
    }

    return services;
}

# =========================================================================
# Dependency resolution — topological sort (Kahn's algorithm)
# =========================================================================

# Build in-degree and dependents maps from service definitions.
# Returns in_degree map via first arg, dependents map via second.
# Both are map_new() maps: name -> count, name -> vec of dependent names.
fn build_dep_graph(svc_defs, in_degree, dependents) {
    for (var i = 0; i < vec_len(svc_defs); i = i + 1) {
        var sd = vec_get(svc_defs, i);
        var name = str_data(svc_def_name(sd));
        if (map_has(in_degree, name) == 0) {
            map_set(in_degree, name, 0);
        }

        var deps = svc_def_deps(sd);
        for (var j = 0; j < vec_len(deps); j = j + 1) {
            var dep = str_data(vec_get(deps, j));
            var deg = map_get(in_degree, name);
            map_set(in_degree, name, deg + 1);

            # Ensure dep target has an in_degree entry (0 if external)
            if (map_has(in_degree, dep) == 0) {
                map_set(in_degree, dep, 0);
            }

            var dep_list = map_get(dependents, dep);
            if (dep_list == 0) {
                dep_list = vec_new();
                map_set(dependents, dep, dep_list);
            }
            vec_push(dep_list, str_from(name));
        }
    }
}

# Resolve startup order for services. Returns vec of service name Strs.
# Returns 0 on error (cycle or missing dependency).
fn resolve_service_order(svc_defs) {
    var count = vec_len(svc_defs);
    if (count == 0) { return vec_new(); }

    var in_degree = map_new();
    var dependents = map_new();
    build_dep_graph(svc_defs, in_degree, dependents);

    # BFS: start with in-degree 0 nodes
    var queue = vec_new();
    var keys = map_keys(in_degree);
    for (var i = 0; i < vec_len(keys); i = i + 1) {
        var key = vec_get(keys, i);
        if (map_get(in_degree, key) == 0) {
            vec_push(queue, str_from(key));
        }
    }

    var ordered = vec_new();
    var qi = 0;
    while (qi < vec_len(queue)) {
        var current = vec_get(queue, qi);
        qi = qi + 1;
        vec_push(ordered, current);

        var dep_list = map_get(dependents, str_data(current));
        if (dep_list != 0) {
            for (var j = 0; j < vec_len(dep_list); j = j + 1) {
                var dep_name = str_data(vec_get(dep_list, j));
                var deg = map_get(in_degree, dep_name);
                deg = deg - 1;
                map_set(in_degree, dep_name, deg);
                if (deg == 0) {
                    vec_push(queue, str_from(dep_name));
                }
            }
        }
    }

    # Cycle detection: compare against total graph nodes (includes external deps)
    if (vec_len(ordered) != map_count(in_degree)) {
        return 0;  # cycle detected
    }

    return ordered;
}

# =========================================================================
# Wave-based startup: group services by dependency depth
# =========================================================================

fn resolve_service_waves(svc_defs) {
    if (vec_len(svc_defs) == 0) { return vec_new(); }

    var in_degree = map_new();
    var dependents = map_new();
    build_dep_graph(svc_defs, in_degree, dependents);

    var total_nodes = map_count(in_degree);
    var waves = vec_new();
    var resolved = 0;

    while (resolved < total_nodes) {
        var wave = vec_new();
        var keys = map_keys(in_degree);

        for (var i = 0; i < vec_len(keys); i = i + 1) {
            var key = vec_get(keys, i);
            if (map_get(in_degree, key) == 0) {
                vec_push(wave, str_from(key));
            }
        }

        if (vec_len(wave) == 0) {
            return 0;  # cycle detected
        }

        # Remove processed nodes and decrement dependents
        for (var i = 0; i < vec_len(wave); i = i + 1) {
            var name = str_data(vec_get(wave, i));
            map_delete(in_degree, name);

            var dep_list = map_get(dependents, name);
            if (dep_list != 0) {
                for (var j = 0; j < vec_len(dep_list); j = j + 1) {
                    var dep_name = str_data(vec_get(dep_list, j));
                    if (map_has(in_degree, dep_name)) {
                        var deg = map_get(in_degree, dep_name);
                        map_set(in_degree, dep_name, deg - 1);
                    }
                }
            }
        }

        resolved = resolved + vec_len(wave);
        vec_push(waves, wave);
    }

    return waves;
}

# =========================================================================
# Crash handling — determine action when a service exits
# =========================================================================

fn on_service_crash(ms, exit_code) {
    var sd = managed_svc_def(ms);
    var policy = svc_def_restart_policy(sd);
    var rc = svc_def_restart_config(sd);
    var restarts = managed_svc_restarts(ms);

    var action = alloc(sizeof(CrashAction));

    if (policy == RESTART_NEVER) {
        store64(action, CRASH_IGNORE);
        return action;
    }

    if (policy == RESTART_ON_FAILURE && exit_code == 0) {
        store64(action, CRASH_IGNORE);
        return action;
    }

    # Policy is Always, or OnFailure with non-zero exit
    if (restart_limit_exceeded(rc, restarts)) {
        store64(action, CRASH_GIVE_UP);
        store64(action + 8, 0);
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "exceeded restart limit (");
        str_builder_add_int(sb, restarts);
        str_builder_add_cstr(sb, "/");
        str_builder_add_int(sb, load64(rc));
        str_builder_add_cstr(sb, ")");
        store64(action + 16, str_builder_build(sb));
        return action;
    }

    var delay = backoff_delay(rc, restarts);
    store64(action, CRASH_RESTART);
    store64(action + 8, delay);
    store64(action + 16, 0);
    return action;
}

# =========================================================================
# Service name validation
# =========================================================================

fn validate_service_name(name) {
    var data = str_data(name);
    var len = str_len(name);
    if (len == 0) { return 0; }

    for (var i = 0; i < len; i = i + 1) {
        var c = load8(data + i);
        # alphanumeric, hyphen, underscore, dot
        var ok = 0;
        if (c >= 48 && c <= 57)  { ok = 1; }
        if (c >= 65 && c <= 90)  { ok = 1; }
        if (c >= 97 && c <= 122) { ok = 1; }
        if (c == 45 || c == 95 || c == 46) { ok = 1; }
        if (ok == 0) { return 0; }
    }

    # Check for path traversal
    if (str_contains(name, str_from(".."))) { return 0; }

    return 1;
}

# =========================================================================
# Default service targets
# =========================================================================

fn default_targets() {
    var targets = vec_new();

    # Basic system services
    var basic = alloc(sizeof(ServiceTarget));
    store64(basic, str_from("basic"));
    store64(basic + 8, str_from("Basic system services"));
    var req = vec_new();
    vec_push(req, str_from("eudev"));
    vec_push(req, str_from("dbus"));
    vec_push(req, str_from("syslogd"));
    store64(basic + 16, req);
    store64(basic + 24, vec_new());
    var active = vec_new();
    vec_push(active, RL_RESCUE);
    vec_push(active, RL_CONSOLE);
    vec_push(active, RL_GRAPHICAL);
    vec_push(active, RL_CONTAINER);
    store64(basic + 32, active);
    vec_push(targets, basic);

    # Network
    var net = alloc(sizeof(ServiceTarget));
    store64(net, str_from("network"));
    store64(net + 8, str_from("Network connectivity"));
    var net_req = vec_new();
    vec_push(net_req, str_from("networkmanager"));
    store64(net + 16, net_req);
    var net_wants = vec_new();
    vec_push(net_wants, str_from("nftables"));
    vec_push(net_wants, str_from("openssh"));
    store64(net + 24, net_wants);
    var net_active = vec_new();
    vec_push(net_active, RL_CONSOLE);
    vec_push(net_active, RL_GRAPHICAL);
    store64(net + 32, net_active);
    vec_push(targets, net);

    # AGNOS core
    var core = alloc(sizeof(ServiceTarget));
    store64(core, str_from("agnos-core"));
    store64(core + 8, str_from("AGNOS agent runtime and LLM gateway"));
    var core_req = vec_new();
    vec_push(core_req, str_from("daimon"));
    store64(core + 16, core_req);
    var core_wants = vec_new();
    vec_push(core_wants, str_from("hoosh"));
    vec_push(core_wants, str_from("aegis"));
    store64(core + 24, core_wants);
    var core_active = vec_new();
    vec_push(core_active, RL_CONSOLE);
    vec_push(core_active, RL_GRAPHICAL);
    vec_push(core_active, RL_CONTAINER);
    store64(core + 32, core_active);
    vec_push(targets, core);

    # Graphical
    var gfx = alloc(sizeof(ServiceTarget));
    store64(gfx, str_from("graphical"));
    store64(gfx + 8, str_from("Desktop environment"));
    var gfx_req = vec_new();
    vec_push(gfx_req, str_from("aethersafha"));
    store64(gfx + 16, gfx_req);
    var gfx_wants = vec_new();
    vec_push(gfx_wants, str_from("pipewire"));
    vec_push(gfx_wants, str_from("agnoshi"));
    store64(gfx + 24, gfx_wants);
    var gfx_active = vec_new();
    vec_push(gfx_active, RL_GRAPHICAL);
    store64(gfx + 32, gfx_active);
    vec_push(targets, gfx);

    # Edge
    var edge = alloc(sizeof(ServiceTarget));
    store64(edge, str_from("edge"));
    store64(edge + 8, str_from("Edge device — minimal agent runtime"));
    var edge_req = vec_new();
    vec_push(edge_req, str_from("daimon"));
    store64(edge + 16, edge_req);
    var edge_wants = vec_new();
    vec_push(edge_wants, str_from("aegis"));
    store64(edge + 24, edge_wants);
    var edge_active = vec_new();
    vec_push(edge_active, RL_EDGE);
    store64(edge + 32, edge_active);
    vec_push(targets, edge);

    return targets;
}
