# =========================================================================
# Service state
# =========================================================================

enum ServiceState {
    STATE_STOPPED;
    STATE_STARTING;
    STATE_RUNNING;
    STATE_STOPPING;
    STATE_FAILED;
}

fn service_state_str(s) {
    if (s == STATE_STOPPED)  { return "stopped"; }
    if (s == STATE_STARTING) { return "starting"; }
    if (s == STATE_RUNNING)  { return "running"; }
    if (s == STATE_STOPPING) { return "stopping"; }
    if (s == STATE_FAILED)   { return "failed"; }
    return "unknown";
}

# Valid state transitions
fn valid_transition(from, to) {
    if (from == to) { return 1; }
    if (from == STATE_STOPPED)  { return to == STATE_STARTING; }
    if (from == STATE_STARTING) { return (to == STATE_RUNNING) || (to == STATE_FAILED); }
    if (from == STATE_RUNNING)  { return (to == STATE_STOPPING) || (to == STATE_FAILED); }
    if (from == STATE_STOPPING) { return (to == STATE_STOPPED) || (to == STATE_FAILED); }
    if (from == STATE_FAILED)   { return (to == STATE_STARTING) || (to == STATE_STOPPED); }
    return 0;
}

# =========================================================================
# Resource limits
# =========================================================================

struct ResourceLimits {
    nofile;         # 0 = not set
    address_space;  # 0 = not set
    nproc;          # 0 = not set
    core;           # -1 = not set, 0 = disabled
}

fn resource_limits_empty() {
    var rl = alloc(sizeof(ResourceLimits));
    store64(rl, 0);
    store64(rl + 8, 0);
    store64(rl + 16, 0);
    store64(rl + 24, 0 - 1);  # core not set
    return rl;
}

# Generate prlimit(1) commands for a PID. Returns vec of SafeCommand ptrs.
fn to_prlimit_commands(rl, pid) {
    var cmds = vec_new();
    var pid_str = str_from_int(pid);

    var nofile = load64(rl);
    if (nofile > 0) {
        var cmd = safe_cmd_new(str_from("prlimit"));
        safe_cmd_add_arg(cmd, str_from("--pid"));
        safe_cmd_add_arg(cmd, pid_str);
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "--nofile=");
        str_builder_add_int(sb, nofile);
        safe_cmd_add_arg(cmd, str_builder_build(sb));
        vec_push(cmds, cmd);
    }

    var addr_space = load64(rl + 8);
    if (addr_space > 0) {
        var cmd = safe_cmd_new(str_from("prlimit"));
        safe_cmd_add_arg(cmd, str_from("--pid"));
        safe_cmd_add_arg(cmd, pid_str);
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "--as=");
        str_builder_add_int(sb, addr_space);
        safe_cmd_add_arg(cmd, str_builder_build(sb));
        vec_push(cmds, cmd);
    }

    var nproc = load64(rl + 16);
    if (nproc > 0) {
        var cmd = safe_cmd_new(str_from("prlimit"));
        safe_cmd_add_arg(cmd, str_from("--pid"));
        safe_cmd_add_arg(cmd, pid_str);
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "--nproc=");
        str_builder_add_int(sb, nproc);
        safe_cmd_add_arg(cmd, str_builder_build(sb));
        vec_push(cmds, cmd);
    }

    var core = load64(rl + 24);
    if (core >= 0) {
        var cmd = safe_cmd_new(str_from("prlimit"));
        safe_cmd_add_arg(cmd, str_from("--pid"));
        safe_cmd_add_arg(cmd, pid_str);
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "--core=");
        str_builder_add_int(sb, core);
        safe_cmd_add_arg(cmd, str_builder_build(sb));
        vec_push(cmds, cmd);
    }

    return cmds;
}

fn resource_limits_secure() {
    var rl = alloc(sizeof(ResourceLimits));
    store64(rl, 0);
    store64(rl + 8, 0);
    store64(rl + 16, 0);
    store64(rl + 24, 0);  # core dumps disabled
    return rl;
}

