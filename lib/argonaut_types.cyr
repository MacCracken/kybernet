# =========================================================================
# Runlevel
# =========================================================================

enum Runlevel {
    RL_EMERGENCY;
    RL_RESCUE;
    RL_CONSOLE;
    RL_GRAPHICAL;
    RL_CONTAINER;
    RL_EDGE;
}

fn runlevel_str(r) {
    if (r == RL_EMERGENCY) { return "emergency"; }
    if (r == RL_RESCUE)    { return "rescue"; }
    if (r == RL_CONSOLE)   { return "console"; }
    if (r == RL_GRAPHICAL) { return "graphical"; }
    if (r == RL_CONTAINER) { return "container"; }
    if (r == RL_EDGE)      { return "edge"; }
    return "unknown";
}

fn runlevel_level(r) {
    if (r == RL_EMERGENCY) { return 0; }
    if (r == RL_RESCUE)    { return 1; }
    if (r == RL_CONSOLE)   { return 3; }
    if (r == RL_GRAPHICAL) { return 5; }
    if (r == RL_CONTAINER) { return 7; }
    if (r == RL_EDGE)      { return 8; }
    return 0 - 1;
}

fn runlevel_to_boot_mode(r) {
    if (r == RL_CONSOLE)   { return BOOT_SERVER; }
    if (r == RL_GRAPHICAL) { return BOOT_DESKTOP; }
    if (r == RL_CONTAINER) { return BOOT_MINIMAL; }
    if (r == RL_EDGE)      { return BOOT_EDGE; }
    return 0 - 1;  # Emergency/Rescue have no boot mode
}

fn boot_mode_to_runlevel(m) {
    if (m == BOOT_SERVER)   { return RL_CONSOLE; }
    if (m == BOOT_DESKTOP)  { return RL_GRAPHICAL; }
    if (m == BOOT_MINIMAL)  { return RL_CONTAINER; }
    if (m == BOOT_EDGE)     { return RL_EDGE; }
    if (m == BOOT_RECOVERY) { return RL_EMERGENCY; }
    return RL_EMERGENCY;
}

