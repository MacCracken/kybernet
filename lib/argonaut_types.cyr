# types.cyr — Argonaut type definitions
# Enums, structs, and configuration types for the init system.
# Ported from rust-old/src/types.rs (1463 lines)

# =========================================================================
# Boot mode
# =========================================================================

enum BootMode {
    BOOT_SERVER;
    BOOT_DESKTOP;
    BOOT_MINIMAL;
    BOOT_EDGE;
    BOOT_RECOVERY;
}

fn boot_mode_str(mode) {
    if (mode == BOOT_SERVER)   { return "server"; }
    if (mode == BOOT_DESKTOP)  { return "desktop"; }
    if (mode == BOOT_MINIMAL)  { return "minimal"; }
    if (mode == BOOT_EDGE)     { return "edge"; }
    if (mode == BOOT_RECOVERY) { return "recovery"; }
    return "unknown";
}

# =========================================================================
# Boot stages
# =========================================================================

enum BootStage {
    STAGE_MOUNT_FS;
    STAGE_DEVICE_MGR;
    STAGE_VERIFY_ROOTFS;
    STAGE_SECURITY;
    STAGE_DATABASE;
    STAGE_AGENT_RUNTIME;
    STAGE_LLM_GATEWAY;
    STAGE_MODEL_SERVICES;
    STAGE_COMPOSITOR;
    STAGE_SHELL;
    STAGE_BOOT_COMPLETE;
}

fn boot_stage_str(stage) {
    if (stage == STAGE_MOUNT_FS)        { return "mount-filesystems"; }
    if (stage == STAGE_DEVICE_MGR)      { return "start-device-manager"; }
    if (stage == STAGE_VERIFY_ROOTFS)   { return "verify-rootfs"; }
    if (stage == STAGE_SECURITY)        { return "start-security"; }
    if (stage == STAGE_DATABASE)        { return "start-database-services"; }
    if (stage == STAGE_AGENT_RUNTIME)   { return "start-agent-runtime"; }
    if (stage == STAGE_LLM_GATEWAY)     { return "start-llm-gateway"; }
    if (stage == STAGE_MODEL_SERVICES)  { return "start-model-services"; }
    if (stage == STAGE_COMPOSITOR)      { return "start-compositor"; }
    if (stage == STAGE_SHELL)           { return "start-shell"; }
    if (stage == STAGE_BOOT_COMPLETE)   { return "boot-complete"; }
    return "unknown";
}

# =========================================================================
# Boot step status
# =========================================================================

enum BootStepStatus {
    STEP_PENDING;
    STEP_RUNNING;
    STEP_COMPLETE;
    STEP_FAILED;
    STEP_SKIPPED;
}

fn step_status_str(s) {
    if (s == STEP_PENDING)  { return "pending"; }
    if (s == STEP_RUNNING)  { return "running"; }
    if (s == STEP_COMPLETE) { return "complete"; }
    if (s == STEP_FAILED)   { return "failed"; }
    if (s == STEP_SKIPPED)  { return "skipped"; }
    return "unknown";
}

# =========================================================================
# Boot step
# =========================================================================

struct BootStep {
    stage;          # BootStage enum
    description;    # Str ptr
    required;       # 1/0
    timeout_ms;     # i64
    status;         # BootStepStatus enum
    started_at;     # epoch ms (0 = not set)
    completed_at;   # epoch ms (0 = not set)
    error;          # Str ptr (0 = no error)
}

fn boot_step_new(stage, desc, required, timeout_ms) {
    var s = alloc(sizeof(BootStep));
    store64(s, stage);
    store64(s + 8, desc);
    store64(s + 16, required);
    store64(s + 24, timeout_ms);
    store64(s + 32, STEP_PENDING);
    store64(s + 40, 0);
    store64(s + 48, 0);
    store64(s + 56, 0);
    return s;
}

# =========================================================================
# Restart policy
# =========================================================================

enum RestartPolicy {
    RESTART_ALWAYS;
    RESTART_ON_FAILURE;
    RESTART_NEVER;
}

fn restart_policy_str(p) {
    if (p == RESTART_ALWAYS)     { return "always"; }
    if (p == RESTART_ON_FAILURE) { return "on-failure"; }
    if (p == RESTART_NEVER)      { return "never"; }
    return "unknown";
}

# =========================================================================
# Restart config
# =========================================================================

#derive(Serialize)
struct RestartConfig {
    max_restarts;    # 0 = unlimited
    base_delay_ms;
    max_delay_ms;
}

fn restart_config_default() {
    var rc = alloc(sizeof(RestartConfig));
    store64(rc, 5);          # max_restarts
    store64(rc + 8, 1000);   # base_delay_ms
    store64(rc + 16, 30000); # max_delay_ms
    return rc;
}

# Exponential backoff delay. Minimum 100ms.
fn backoff_delay(rc, restart_count) {
    var base = load64(rc + 8);  # base_delay_ms
    var cap = load64(rc + 16);  # max_delay_ms
    if (base < 100) { base = 100; }
    if (cap < 100)  { cap = 100; }
    # 2^restart_count * base, saturating
    var shift = 1;
    for (var i = 0; i < restart_count; i = i + 1) {
        if (shift > 1000000000) { shift = 1000000000; break; }
        shift = shift * 2;
    }
    var delay = base * shift;
    if (delay > cap) { delay = cap; }
    return delay;
}

fn restart_limit_exceeded(rc, restart_count) {
    var max = load64(rc);  # max_restarts
    if (max == 0) { return 0; }
    return restart_count >= max;
}

