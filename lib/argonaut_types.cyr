# =========================================================================
# Service definition — static configuration for a managed service
# =========================================================================

struct ServiceDefinition {
    name;                # Str ptr
    description;         # Str ptr
    binary_path;         # Str ptr
    args;                # vec of Str ptrs
    environment;         # map of Str -> Str
    depends_on;          # vec of Str ptrs
    required_for_modes;  # vec of BootMode values
    restart_policy;      # RestartPolicy enum
    restart_config;      # ptr to RestartConfig
    health_check;        # ptr to HealthCheck (0 = none)
    ready_check;         # ptr to ReadyCheck (0 = none)
    enabled;             # 1/0
    service_type;        # ServiceType enum
    env_files;           # vec of Str ptrs
    pid_file;            # Str ptr (0 = none)
    resource_limits;     # ptr to ResourceLimits (0 = none)
    log_config;          # ptr to LogConfig (0 = none)
    socket_activation;   # vec of socket specs (0 = none)
    seccomp;             # seccomp config (0 = none)
    landlock;            # landlock config (0 = none)
    capabilities;        # vec of capabilities to drop (0 = none)
}

fn svc_def_new(name, desc, binary) {
    var sd = alloc(sizeof(ServiceDefinition));
    store64(sd, name);
    store64(sd + 8, desc);
    store64(sd + 16, binary);
    store64(sd + 24, vec_new());        # args
    store64(sd + 32, map_new());        # environment
    store64(sd + 40, vec_new());        # depends_on
    store64(sd + 48, vec_new());        # required_for_modes
    store64(sd + 56, RESTART_ON_FAILURE);
    store64(sd + 64, restart_config_default());
    store64(sd + 72, 0);                # health_check
    store64(sd + 80, 0);                # ready_check
    store64(sd + 88, 1);                # enabled
    store64(sd + 96, SVC_SIMPLE);
    store64(sd + 104, vec_new());       # env_files
    store64(sd + 112, 0);               # pid_file
    store64(sd + 120, 0);               # resource_limits
    store64(sd + 128, 0);               # log_config
    store64(sd + 136, 0);               # socket_activation
    store64(sd + 144, 0);               # seccomp
    store64(sd + 152, 0);               # landlock
    store64(sd + 160, 0);               # capabilities
    return sd;
}

# Accessors for ServiceDefinition
fn svc_def_name(sd)          { return load64(sd); }
fn svc_def_desc(sd)          { return load64(sd + 8); }
fn svc_def_binary(sd)        { return load64(sd + 16); }
fn svc_def_args(sd)          { return load64(sd + 24); }
fn svc_def_env(sd)           { return load64(sd + 32); }
fn svc_def_deps(sd)          { return load64(sd + 40); }
fn svc_def_modes(sd)         { return load64(sd + 48); }
fn svc_def_restart_policy(sd){ return load64(sd + 56); }
fn svc_def_restart_config(sd){ return load64(sd + 64); }
fn svc_def_health_check(sd)  { return load64(sd + 72); }
fn svc_def_ready_check(sd)   { return load64(sd + 80); }
fn svc_def_enabled(sd)       { return load64(sd + 88); }
fn svc_def_service_type(sd)  { return load64(sd + 96); }
fn svc_def_env_files(sd)     { return load64(sd + 104); }
fn svc_def_pid_file(sd)      { return load64(sd + 112); }
fn svc_def_rlimits(sd)       { return load64(sd + 120); }
fn svc_def_log_config(sd)    { return load64(sd + 128); }

# =========================================================================
# Managed service — runtime state of a service
# =========================================================================

struct ManagedService {
    definition;          # ptr to ServiceDefinition
    state;               # ServiceState enum
    pid;                 # i64 (0 = not running)
    started_at;          # epoch ms (0 = not started)
    restart_count;       # i64
    last_health_check;   # epoch ms (0 = never)
}

fn managed_svc_new(definition) {
    var ms = alloc(sizeof(ManagedService));
    store64(ms, definition);
    store64(ms + 8, STATE_STOPPED);
    store64(ms + 16, 0);
    store64(ms + 24, 0);
    store64(ms + 32, 0);
    store64(ms + 40, 0);
    return ms;
}

fn managed_svc_def(ms)      { return load64(ms); }
fn managed_svc_state(ms)    { return load64(ms + 8); }
fn managed_svc_pid(ms)      { return load64(ms + 16); }
fn managed_svc_started(ms)  { return load64(ms + 24); }
fn managed_svc_restarts(ms) { return load64(ms + 32); }
fn managed_svc_last_hc(ms)  { return load64(ms + 40); }

fn managed_svc_set_state(ms, state)     { store64(ms + 8, state); }
fn managed_svc_set_pid(ms, pid)         { store64(ms + 16, pid); }
fn managed_svc_set_started(ms, ts)      { store64(ms + 24, ts); }
fn managed_svc_set_restarts(ms, n)      { store64(ms + 32, n); }
fn managed_svc_set_last_hc(ms, ts)      { store64(ms + 40, ts); }

# =========================================================================
# Edge boot config
# =========================================================================

#derive(Serialize)
struct EdgeBootConfig {
    readonly_rootfs;     # 1/0
    luks_enabled;        # 1/0
    tpm_attestation;     # 1/0
    max_boot_ms;
    pcr_bindings;        # Str ptr
}

fn edge_config_default() {
    var ec = alloc(sizeof(EdgeBootConfig));
    store64(ec, 1);                      # readonly_rootfs
    store64(ec + 8, 1);                  # luks_enabled
    store64(ec + 16, 1);                 # tpm_attestation
    store64(ec + 24, 3000);              # max_boot_time_ms
    store64(ec + 32, str_from("7+14"));  # pcr_bindings
    return ec;
}

# =========================================================================
# Argonaut config — top-level configuration
# =========================================================================

struct ArgonautConfig {
    boot_mode;
    services;            # vec of ServiceDefinition ptrs
    boot_timeout_ms;
    shutdown_timeout_ms;
    log_to_console;      # 1/0
    verify_on_boot;      # 1/0
    edge_boot;           # ptr to EdgeBootConfig
    tmpfiles;            # vec of tmpfile entries
}

fn argonaut_config_default() {
    var cfg = alloc(sizeof(ArgonautConfig));
    store64(cfg, BOOT_DESKTOP);
    store64(cfg + 8, vec_new());
    store64(cfg + 16, 30000);
    store64(cfg + 24, 10000);
    store64(cfg + 32, 1);
    store64(cfg + 40, 1);
    store64(cfg + 48, edge_config_default());
    store64(cfg + 56, vec_new());
    return cfg;
}

fn config_boot_mode(cfg)          { return load64(cfg); }
fn config_services(cfg)           { return load64(cfg + 8); }
fn config_boot_timeout(cfg)       { return load64(cfg + 16); }
fn config_shutdown_timeout(cfg)   { return load64(cfg + 24); }
fn config_log_console(cfg)        { return load64(cfg + 32); }
fn config_verify_boot(cfg)        { return load64(cfg + 40); }
fn config_edge(cfg)               { return load64(cfg + 48); }
fn config_tmpfiles(cfg)           { return load64(cfg + 56); }

# =========================================================================
# Argonaut stats — snapshot of init-system statistics
# =========================================================================

#derive(Serialize)
struct ArgonautStats {
    boot_mode;
    boot_dur_ms;        # 0 = not complete
    svcs_running;
    svcs_failed;
    total_restarts;
    boot_complete;      # 1/0
}

# =========================================================================
# Shutdown step
# =========================================================================

struct ShutdownStep {
    description;        # Str ptr
    action;             # ShutdownAction enum
    action_data;        # Str ptr (service name, message, or ShutdownType)
    signal;             # signal number for SA_STOP_SERVICE
    timeout_ms;
    status;             # ShutdownStepStatus enum
}

fn shutdown_step_new(desc, action, data, signal, timeout_ms) {
    var ss = alloc(sizeof(ShutdownStep));
    store64(ss, desc);
    store64(ss + 8, action);
    store64(ss + 16, data);
    store64(ss + 24, signal);
    store64(ss + 32, timeout_ms);
    store64(ss + 40, SS_PENDING);
    return ss;
}

# =========================================================================
# Shutdown plan
# =========================================================================

struct ShutdownPlan {
    shutdown_type;       # ShutdownType enum
    steps;               # vec of ShutdownStep ptrs
    timeout_ms;
    wall_message;        # Str ptr (0 = none)
}

# =========================================================================
# Runlevel switch plan
# =========================================================================

struct RunlevelSwitchPlan {
    from;                # Runlevel
    to;                  # Runlevel
    services_to_start;   # vec of Str
    services_to_stop;    # vec of Str
    drop_to_shell;       # 1/0
}

# =========================================================================
# Runlevel switch result
# =========================================================================

struct RunlevelSwitchResult {
    from;
    to;
    stopped;             # vec of Str
    started;             # vec of Str
    errors;              # vec of Str
    drop_to_shell;       # 1/0
}

# =========================================================================
# Health check result
# =========================================================================

#derive(Serialize)
struct HealthCheckResult {
    service;            # Str ptr
    check_type_str;     # Str ptr
    passed;             # 1/0
    latency_ms;
    message;            # Str ptr (0 = none)
    checked_at;         # epoch ms
}

# =========================================================================
# Health tracker — consecutive failure counts
# =========================================================================

# Uses a map: service name -> consecutive failure count
fn health_tracker_new() {
    return map_new();
}

fn health_tracker_record(tracker, service, passed, threshold) {
    if (passed) {
        map_delete(tracker, service);
        return 0;  # no restart needed
    }
    var count = map_get(tracker, service);
    count = count + 1;
    map_set(tracker, service, count);
    return count >= threshold;  # 1 = should restart
}

fn health_tracker_count(tracker, service) {
    return map_get(tracker, service);
}

fn health_tracker_reset(tracker, service) {
    map_delete(tracker, service);
}

# =========================================================================
# SafeCommand — injection-resistant command representation
# =========================================================================

struct SafeCommand {
    binary;             # Str ptr
    args;               # vec of Str ptrs
}

fn safe_cmd_new(binary) {
    var sc = alloc(sizeof(SafeCommand));
    store64(sc, binary);
    store64(sc + 8, vec_new());
    return sc;
}

fn safe_cmd_add_arg(sc, arg) {
    vec_push(load64(sc + 8), arg);
}

fn safe_cmd_binary(sc) { return load64(sc); }
fn safe_cmd_args(sc)   { return load64(sc + 8); }

# Display: "binary arg1 arg2 ..."
fn safe_cmd_display(sc) {
    var sb = str_builder_new();
    str_builder_add(sb, safe_cmd_binary(sc));
    var args = safe_cmd_args(sc);
    for (var i = 0; i < vec_len(args); i = i + 1) {
        str_builder_add_cstr(sb, " ");
        str_builder_add(sb, vec_get(args, i));
    }
    return str_builder_build(sb);
}

# =========================================================================
# Tmpfile entry types
# =========================================================================

enum TmpfileType {
    TMP_DIRECTORY;
    TMP_SYMLINK;
    TMP_DEVICE;
}

struct TmpfileEntry {
    entry_type;         # TmpfileType
    path;               # Str ptr
    target;             # Str ptr (for symlink)
    mode;               # octal mode
    uid;                # -1 = not set
    gid;                # -1 = not set
    dev_type;           # 'b' or 'c' (for device)
    major;              # device major
    minor;              # device minor
}

# =========================================================================
# Service target — groups related services
# =========================================================================

struct ServiceTarget {
    name;               # Str ptr
    description;        # Str ptr
    requires;           # vec of Str
    wants;              # vec of Str
    active_in;          # vec of Runlevel values
}

# =========================================================================
# Emergency shell config
# =========================================================================

struct EmergencyShellConfig {
    shell_path;          # Str ptr
    environment;         # map of Str -> Str
    banner;              # Str ptr
    require_auth;        # 1/0
    auth_password_hash;  # Str ptr (0 = none)
}

fn emergency_shell_default() {
    var esc = alloc(sizeof(EmergencyShellConfig));
    store64(esc, str_from("/usr/bin/agnoshi"));
    var env = map_new();
    map_set(env, "HOME", str_from("/root"));
    map_set(env, "TERM", str_from("linux"));
    map_set(env, "PATH", str_from("/usr/sbin:/usr/bin:/sbin:/bin"));
    map_set(env, "SHELL", str_from("/usr/bin/agnoshi"));
    store64(esc + 8, env);
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "\n========================================\n");
    str_builder_add_cstr(sb, "  AGNOS Emergency Shell\n");
    str_builder_add_cstr(sb, "========================================\n\n");
    str_builder_add_cstr(sb, "The system has entered emergency mode.\n");
    str_builder_add_cstr(sb, "Use 'argonaut status' to check service state.\n");
    str_builder_add_cstr(sb, "Use 'argonaut start <service>' to start services.\n");
    str_builder_add_cstr(sb, "Use 'exit' to continue boot or 'reboot' to restart.\n");
    store64(esc + 16, str_builder_build(sb));
    store64(esc + 24, 0);   # require_auth = false
    store64(esc + 32, 0);   # no password hash
    return esc;
}

# =========================================================================
# Edge boot result
# =========================================================================

struct EdgeBootResult {
    rootfs_locked;       # 1/0
    verity_verified;     # 1/0
    luks_unlocked;       # 1/0
    boot_time_ms;
    within_budget;       # 1/0
    errors;              # vec of Str
}

# =========================================================================
# Fleet registration (edge auto-registration)
# =========================================================================

#derive(Serialize)
struct FleetRegistration {
    machine_id;          # Str ptr
    hostname;            # Str ptr
    boot_mode_str;       # Str ptr
    verity_active;       # 1/0
    luks_active;         # 1/0
    kernel_ver;          # Str ptr
    total_mem_mb;
}

# =========================================================================
# Timestamp helper — epoch milliseconds via clock_gettime
# =========================================================================

fn now_ms() {
    var buf[16];
    # clock_gettime(CLOCK_REALTIME=0, &timespec)
    syscall(228, 0, &buf);
    var sec = load64(&buf);
    var nsec = load64(&buf + 8);
    return sec * 1000 + nsec / 1000000;
}

# Monotonic clock for uptime/elapsed measurements
fn monotonic_ms() {
    var buf[16];
    # clock_gettime(CLOCK_MONOTONIC=1, &timespec)
    syscall(228, 1, &buf);
    var sec = load64(&buf);
    var nsec = load64(&buf + 8);
    return sec * 1000 + nsec / 1000000;
}
