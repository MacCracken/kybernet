enum HealthCheckType {
    HC_HTTP_GET;
    HC_TCP_CONNECT;
    HC_COMMAND;
    HC_PROCESS_ALIVE;
}

fn health_check_type_str(t) {
    if (t == HC_HTTP_GET) { return "http"; }
    if (t == HC_TCP_CONNECT) { return "tcp"; }
    if (t == HC_COMMAND) { return "command"; }
    if (t == HC_PROCESS_ALIVE) { return "process-alive"; }
    return "unknown";
}

# =========================================================================
# Health check
# =========================================================================

struct HealthCheck {
    check_type;     # HealthCheckType enum
    target;         # Str ptr (URL, host, or command)
    port;           # port for TCP (0 if not applicable)
    interval_ms;
    timeout_ms;
    retries;
}

fn health_check_new(check_type, target, port, interval_ms, timeout_ms, retries) {
    var hc = alloc(sizeof(HealthCheck));
    store64(hc, check_type);
    store64(hc + 8, target);
    store64(hc + 16, port);
    store64(hc + 24, interval_ms);
    store64(hc + 32, timeout_ms);
    store64(hc + 40, retries);
    return hc;
}

# =========================================================================
# Ready check
# =========================================================================

struct ReadyCheck {
    check_type;     # HealthCheckType enum
    target;         # Str ptr
    port;           # port for TCP
    timeout_ms;
    retries;
    retry_delay_ms;
}

fn ready_check_new(check_type, target, port, timeout_ms, retries, retry_delay_ms) {
    var rc = alloc(sizeof(ReadyCheck));
    store64(rc, check_type);
    store64(rc + 8, target);
    store64(rc + 16, port);
    store64(rc + 24, timeout_ms);
    store64(rc + 32, retries);
    store64(rc + 40, retry_delay_ms);
    return rc;
}

