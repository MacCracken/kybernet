fn health_check_new() {
    var h = alloc(40);
    store64(h, PROBE_LIVENESS_READINESS);
    store64(h + 8, 30);    # 30s interval
    store64(h + 16, 5);    # 5s timeout
    store64(h + 24, 3);    # 3 retries
    store64(h + 32, 0);    # no initial delay
    return h;
}
