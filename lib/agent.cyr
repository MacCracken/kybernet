fn agent_config_new(name) {
    var c = alloc(104);
    store64(c, name);
    store64(c + 8, AGENT_TYPE_USER);
    store64(c + 16, resource_limits_new());
    store64(c + 24, 0);   # sandbox set later
    store64(c + 32, 0);
    store64(c + 40, 0);
    store64(c + 48, RESTART_NEVER);
    store64(c + 56, 3);
    store64(c + 64, 0);
    store64(c + 72, 0);
    store64(c + 80, 0);
    store64(c + 88, 0);
    store64(c + 96, 0);
    return c;
}
