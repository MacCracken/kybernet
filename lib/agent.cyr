enum AgentType {
    AGENT_TYPE_SYSTEM;
    AGENT_TYPE_USER;
    AGENT_TYPE_SERVICE;
}
enum AgentStatus {
    AGENT_PENDING;
    AGENT_STARTING;
    AGENT_RUNNING;
    AGENT_PAUSED;
    AGENT_STOPPING;
    AGENT_STOPPED;
    AGENT_RESTARTING;
    AGENT_TERMINATED;
    AGENT_FAILED;
}
enum RestartPolicy {
    RESTART_NEVER;
    RESTART_ALWAYS;
    RESTART_ON_FAILURE;
}
enum ProbeType {
    PROBE_LIVENESS_READINESS;
    PROBE_LIVENESS;
    PROBE_READINESS;
    PROBE_STARTUP;
}
enum StopReason {
    STOP_USER_REQUESTED;
    STOP_RESOURCE_EXHAUSTED;
    STOP_ERROR;
    STOP_TIMEOUT;
    STOP_SYSTEM_SHUTDOWN;
}
fn stop_reason_new(kind, message) {
    return tagged_new(kind, message);
}
fn stop_reason_kind(sr) { return tag(sr); }
fn stop_reason_message(sr) { return payload(sr); }
enum CircuitBreakerState {
    CB_CLOSED;
    CB_OPEN;
    CB_HALF_OPEN;
}
#derive(Serialize)
struct ResourceLimits { max_memory; max_cpu_time; max_fds; max_procs; max_disk; net_bw; }
fn ResourceLimits_to_json(ptr, sb) {
    str_builder_add_cstr(sb, "{\"max_memory\": ");
        str_builder_add_int(sb, load64(ptr));
        str_builder_add_cstr(sb, ", \"max_cpu_time\": ");
        str_builder_add_int(sb, load64(ptr + 8));
        str_builder_add_cstr(sb, ", \"max_fds\": ");
        str_builder_add_int(sb, load64(ptr + 16));
        str_builder_add_cstr(sb, ", \"max_procs\": ");
        str_builder_add_int(sb, load64(ptr + 24));
        str_builder_add_cstr(sb, ", \"max_disk\": ");
        str_builder_add_int(sb, load64(ptr + 32));
        str_builder_add_cstr(sb, ", \"net_bw\": ");
        str_builder_add_int(sb, load64(ptr + 40));
        str_builder_add_cstr(sb, "}");
    return 0;
}
fn ResourceLimits_from_json(src) {
    var r = alloc(48);
    store64(r, _json_int(src, str_from("max_memory")));
    store64(r + 8, _json_int(src, str_from("max_cpu_time")));
    store64(r + 16, _json_int(src, str_from("max_fds")));
    store64(r + 24, _json_int(src, str_from("max_procs")));
    store64(r + 32, _json_int(src, str_from("max_disk")));
    store64(r + 40, _json_int(src, str_from("net_bw")));
    return r;
}
fn resource_limits_new() {
    var r = alloc(48);
    store64(r, 268435456);     # 256 MB default
    store64(r + 8, 3600);      # 1 hour default
    store64(r + 16, 256);      # 256 fds
    store64(r + 24, 64);       # 64 processes
    store64(r + 32, 0);
    store64(r + 40, 0);
    return r;
}
fn rlim_max_memory(r)           { return load64(r); }
fn rlim_max_cpu_time(r)         { return load64(r + 8); }
fn rlim_max_fds(r)              { return load64(r + 16); }
fn rlim_max_procs(r)            { return load64(r + 24); }
fn rlim_max_disk(r)             { return load64(r + 32); }
fn rlim_net_bandwidth(r)        { return load64(r + 40); }
fn rlim_set_max_memory(r, v)    { store64(r, v); return 0; }
fn rlim_set_max_cpu(r, v)       { store64(r + 8, v); return 0; }
fn rlim_set_max_fds(r, v)       { store64(r + 16, v); return 0; }
fn rlim_set_max_procs(r, v)     { store64(r + 24, v); return 0; }
fn rlim_set_max_disk(r, v)      { store64(r + 32, v); return 0; }
fn rlim_set_net_bw(r, v)        { store64(r + 40, v); return 0; }
