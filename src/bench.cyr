# ================================================================
# Str builder (used everywhere for path construction)
# ================================================================

fn bench_str_builder() {
    var iters = 100000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "/sys/fs/cgroup/");
        str_builder_add_cstr(sb, "kybernet.slice/");
