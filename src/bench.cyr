# ================================================================
# OwnedFd create + close
# ================================================================

fn bench_owned_fd() {
    var iters = 500000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        var ofd = owned_fd_new(42);
        owned_fd_raw(ofd);
        store64(ofd, 0 - 1);
        k = k + 1;
    }
    report("owned_fd_new+raw", now_ns() - start, iters);
    return 0;
}

# ================================================================
# Memory comparison (hot path in notify parse)
# ================================================================

fn bench_memeq() {
    var iters = 1000000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        memeq("READY=1", "READY=1", 7);
        memeq("STATUS=running", "STOPPING=1", 10);
        k = k + 1;
    }
    report("memeq (2 calls)", now_ns() - start, iters);
    return 0;
}

fn bench_strlen() {
    var iters = 1000000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        strlen("/sys/fs/cgroup/kybernet.slice/myservice/cgroup.procs");
        k = k + 1;
    }
    report("strlen(52 chars)", now_ns() - start, iters);
    return 0;
