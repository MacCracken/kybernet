# ================================================================
# Seccomp agnostik bridge (cold path — per service)
# ================================================================

fn bench_seccomp_from_profile() {
    var iters = 10000;
    var prof = seccomp_profile_new(SECCOMP_KILL_PROCESS);
    var rules = scprof_syscalls(prof);
    var rule = seccomp_rule_new(SECCOMP_ALLOW);
    var names = scrule_names(rule);
    vec_push(names, 0);
    vec_push(names, 1);
    vec_push(names, 3);
    vec_push(names, 60);
    vec_push(names, 231);
    vec_push(rules, rule);

    var start = now_ns();
    var k = 0;
    while (k < iters) {
        seccomp_from_profile(prof);
        k = k + 1;
    }
    report("seccomp_from_profile", now_ns() - start, iters);
    return 0;
}

