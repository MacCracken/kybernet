}

# ================================================================
# Epoll wait cycle (hot path — every event loop iteration)
# ================================================================

fn bench_epoll_wait_immediate() {
    # Create epoll with a timer, then wait with timeout=0 (immediate return)
    var epfd_r = epoll_new();
    var epfd = result_unwrap(epfd_r);
    var tfd_r = timer_new(999);
    var tfd = result_unwrap(tfd_r);
    epoll_add_read(epfd, tfd, TOKEN_HEALTH);

    var iters = 100000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        epoll_wait_events(epfd, 8, 0);
        k = k + 1;
    }
    report("epoll_wait(timeout=0)", now_ns() - start, iters);
    sys_close(tfd);
    owned_fd_close(epfd);
    return 0;
}

fn bench_event_accessors() {
    var iters = 1000000;
    var ev = alloc(16);
    store64(ev, 42);
    store64(ev + 8, EPOLLIN);
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        event_token(ev);
        event_flags(ev);
        k = k + 1;
    }
    report("event_token+flags", now_ns() - start, iters);
    return 0;
}

# ================================================================
# Logging cost (hot path — every event)
# Simulates klog: 3x sys_write to stderr per message
# ================================================================

fn bench_klog_sim() {
    # Write to /dev/null to measure syscall cost without actual stderr
    var fd = sys_open("/dev/null", O_WRONLY, 0);
    if (fd < 0) { return 0; }
    var iters = 100000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        sys_write(fd, "kybernet: ", 10);
        sys_write(fd, "bench message", 13);
        sys_write(fd, "\n", 1);
        k = k + 1;
    }
    report("klog_sim(3 writes)", now_ns() - start, iters);
    sys_close(fd);
    return 0;
}

fn bench_klog2_sim() {
    var fd = sys_open("/dev/null", O_WRONLY, 0);
    if (fd < 0) { return 0; }
    var iters = 100000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        sys_write(fd, "kybernet: ", 10);
        sys_write(fd, "service exited: ", 16);
        sys_write(fd, "daimon", 6);
        sys_write(fd, "\n", 1);
        k = k + 1;
    }
    report("klog2_sim(4 writes)", now_ns() - start, iters);
    sys_close(fd);
    return 0;
}

