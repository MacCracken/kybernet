# ================================================================
# Epoll lifecycle (create + add + close)
# ================================================================

fn bench_epoll_lifecycle() {
    var iters = 10000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        var epfd_r = epoll_new();
        if (is_ok(epfd_r) == 1) {
            var epfd = result_unwrap(epfd_r);
            var tfd_r = timer_new(1);
            if (is_ok(tfd_r) == 1) {
                epoll_add_read(epfd, result_unwrap(tfd_r), TOKEN_HEALTH);
                sys_close(result_unwrap(tfd_r));
            }
            owned_fd_close(epfd);
        }
        k = k + 1;
    }
    report("epoll(new+add+close)", now_ns() - start, iters);
    return 0;
}

# ================================================================
# Hashmap (used for service name → pid tracking)
# ================================================================

fn bench_hashmap() {
    var iters = 10000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        var m = map_new();
        map_set(m, "daimon", 1234);
        map_set(m, "redis", 1235);
        map_set(m, "postgres", 1236);
        map_get(m, "daimon");
        map_get(m, "redis");
        map_has(m, "postgres");
        map_has(m, "missing");
        k = k + 1;
    }
    report("hashmap(3 set+4 get/has)", now_ns() - start, iters);
    return 0;
}

# ================================================================
# Main
# ================================================================

fn main() {
    alloc_init();

    println("===================================================");
    println("  kybernet benchmark — Cyrius");
    println("===================================================");
    println("");

    # --- Syscall baselines ---
    println("Syscall baselines:");
    bench_getpid();
    bench_getuid();
    bench_is_root();
    println("");

    # --- Signal handling ---
    println("Signal handling:");
    bench_classify_signal();
    bench_is_handled_signal();
    bench_sigset_ops();
    println("");

    # --- Event loop ---
    println("Event loop:");
    bench_epoll_event_new();
    bench_timerspec_new();
    bench_wait_macros();
    println("");

    # --- Notify ---
    println("Notify socket:");
    bench_knotify_classify();
    bench_knotify_classify_status();
    println("");

    # --- Cgroup ---
    println("Cgroup management:");
    alloc_reset();
    alloc_init();
    bench_cgroup_path();
    alloc_reset();
    alloc_init();
    bench_cgroup_file();
    println("");

    # --- Mount ---
    println("Mount operations:");
    bench_is_mounted();
    println("");

    # --- Security (cold path) ---
    println("Security (pre_exec):");
    alloc_reset();
    alloc_init();
    bench_seccomp_build_small();
    alloc_reset();
    alloc_init();
    bench_seccomp_build_basic();
    alloc_reset();
    alloc_init();
    bench_sandbox_build();
    println("");

    # --- String building ---
    println("String operations:");
    alloc_reset();
    alloc_init();
    bench_str_builder();
    alloc_reset();
    alloc_init();
    bench_str_builder_int();
    println("");

    # --- Result/Option ---
    println("Tagged types:");
    bench_result_ok();
    bench_result_err();
    bench_option();
    println("");

    # --- Collections ---
    println("Collections:");
    alloc_reset();
    alloc_init();
    bench_vec_push_get();
    println("");

    # --- Mount ---
    println("Mount table:");
    bench_mount_table_init();
    println("");

    # --- OwnedFd ---
    println("OwnedFd:");
    alloc_reset();
    alloc_init();
    bench_owned_fd();
    println("");

    # --- Memeq (used in notify classify) ---
    println("Memory ops:");
    bench_memeq();
    bench_strlen();
    println("");

    # --- Epoll lifecycle ---
    println("Epoll lifecycle:");
    alloc_reset();
    alloc_init();
    bench_epoll_lifecycle();
    println("");

    # --- Hashmap (used in service tracking) ---
    println("Hashmap:");
    alloc_reset();
    alloc_init();
    bench_hashmap();
    println("");

    println("done");
    return 0;
}

var r = main();
syscall(60, r);
