# ================================================================
# Memcpy + memset (used in notify, sandbox)
# ================================================================

fn bench_memcpy() {
    var src = alloc(128);
    var dst = alloc(128);
    memset(src, 65, 128);
    var iters = 1000000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        memcpy(dst, src, 128);
        k = k + 1;
    }
    report("memcpy(128 bytes)", now_ns() - start, iters);
    return 0;
}

fn bench_memset() {
    var buf = alloc(128);
    var iters = 1000000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        memset(buf, 0, 128);
        k = k + 1;
    }
    report("memset(128 bytes)", now_ns() - start, iters);
    return 0;
}

