fn bench_sandbox_rule_new() {
    var iters = 100000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        var b = sandbox_builder_new();
        sandbox_allow_read(b, "/etc");
        sandbox_allow_read_write(b, "/tmp");
        sandbox_allow_read_exec(b, "/usr/bin");
        sandbox_rule_count(b);
        k = k + 1;
    }
    report("sandbox(new+3 rules+count)", now_ns() - start, iters);
    return 0;
}

fn bench_sandbox_from_ruleset() {
    var iters = 10000;
    var llrs = landlock_ruleset_new();
    var fs = llrs_fs_rules(llrs);
    var r1 = landlock_fs_rule_new("/etc");
    var a1 = llfsr_allowed_access(r1);
    vec_push(a1, LL_READ_FILE);
    vec_push(a1, LL_READ_DIR);
    vec_push(fs, r1);
    var r2 = landlock_fs_rule_new("/tmp");
    var a2 = llfsr_allowed_access(r2);
    vec_push(a2, LL_READ_FILE);
    vec_push(a2, LL_WRITE_FILE);
    vec_push(fs, r2);

    var start = now_ns();
    var k = 0;
    while (k < iters) {
        sandbox_from_ruleset(llrs);
        k = k + 1;
    }
    report("sandbox_from_ruleset(2 rules)", now_ns() - start, iters);
    return 0;
}

