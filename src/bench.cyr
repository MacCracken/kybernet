# kybernet_bench.cyr — benchmark suite for kybernet modules
# Measures per-operation costs for PID 1 hot paths.
#
# Build: sh scripts/bench.sh
# Run:   ./build/kybernet_bench

# Kybernet modules (deps resolved via cyrb.toml)
include "src/lib/console.cyr"
include "src/lib/signals.cyr"
include "src/lib/reaper.cyr"
include "src/lib/privdrop.cyr"
include "src/lib/mount.cyr"
include "src/lib/cgroup.cyr"
include "src/lib/eventloop.cyr"
include "src/lib/notify.cyr"
include "src/lib/seccomp.cyr"
include "src/lib/sandbox.cyr"

# ================================================================
# Inline report (matches agnosys bench_compare format)
# ================================================================

fn report(name, total_ns, iterations) {
    var per_op = total_ns / iterations;
    syscall(1, 1, "  ", 2);
    syscall(1, 1, name, strlen(name));
    syscall(1, 1, ": ", 2);
    print_num(per_op);
    syscall(1, 1, " ns/op (", 8);
    print_num(iterations);
    syscall(1, 1, " iters, ", 8);
    print_num(total_ns / 1000000);
    syscall(1, 1, " ms total)\n", 11);
    return 0;
}

# ================================================================
# Syscall baselines (parity with agnosys bench_compare)
# ================================================================

fn bench_getpid() {
    var iters = 1000000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        sys_getpid();
        k = k + 1;
    }
    report("getpid", now_ns() - start, iters);
    return 0;
}

fn bench_getuid() {
    var iters = 1000000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        sys_getuid();
        k = k + 1;
    }
    report("getuid", now_ns() - start, iters);
    return 0;
}

