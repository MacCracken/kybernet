# ================================================================
# Vec operations (used in reaper, event loop)
# ================================================================

fn bench_vec_push_get() {
    var iters = 100000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        var v = vec_new();
        vec_push(v, 1);
        vec_push(v, 2);
        vec_push(v, 3);
        vec_get(v, 0);
        vec_get(v, 2);
        vec_len(v);
        k = k + 1;
    }
    report("vec(push*3+get*2+len)", now_ns() - start, iters);
    return 0;
}

