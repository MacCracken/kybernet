# ================================================================
# Seccomp filter building (cold path — once per service start)
# ================================================================

fn bench_seccomp_build_basic() {
    var iters = 5000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        var b = seccomp_basic_service();
        var r = seccomp_build(b);
        k = k + 1;
    }
    report("seccomp_basic_service+build", now_ns() - start, iters);
    return 0;
}

fn bench_seccomp_build_small() {
    var iters = 50000;
    var start = now_ns();
    var k = 0;
    while (k < iters) {
        var b = seccomp_builder_new();
        seccomp_allow(b, 0);
        seccomp_allow(b, 1);
        seccomp_allow(b, 3);
        seccomp_allow(b, 60);
        seccomp_allow(b, 231);
        var r = seccomp_build(b);
        k = k + 1;
    }
    report("seccomp_build(5 syscalls)", now_ns() - start, iters);
    return 0;
}

