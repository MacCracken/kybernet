# kybernet/sandbox.cyr — Landlock filesystem sandbox for service pre_exec
# Requires: agnosys/syscalls.cyr, string.cyr, vec.cyr, tagged.cyr
#
# Applies Landlock filesystem restrictions in pre_exec.
# Graceful fallback on kernels without Landlock (< 5.13).
# Uses raw syscalls — no dependency on agnosys/security.cyr.

# Landlock syscall numbers (x86_64, kernel 5.13+)
enum LandlockSysNr {
    SYS_LANDLOCK_CREATE_RULESET = 444;
    SYS_LANDLOCK_ADD_RULE = 445;
    SYS_LANDLOCK_RESTRICT_SELF = 446;
}

# Landlock access flags
enum LandlockAccess {
    LANDLOCK_ACCESS_FS_EXECUTE = 1;
    LANDLOCK_ACCESS_FS_WRITE_FILE = 2;
    LANDLOCK_ACCESS_FS_READ_FILE = 4;
    LANDLOCK_ACCESS_FS_READ_DIR = 8;
    LANDLOCK_ACCESS_FS_REMOVE_DIR = 16;
    LANDLOCK_ACCESS_FS_REMOVE_FILE = 32;
    LANDLOCK_ACCESS_FS_MAKE_CHAR = 64;
    LANDLOCK_ACCESS_FS_MAKE_DIR = 128;
    LANDLOCK_ACCESS_FS_MAKE_REG = 256;
    LANDLOCK_ACCESS_FS_MAKE_SOCK = 512;
    LANDLOCK_ACCESS_FS_MAKE_FIFO = 1024;
    LANDLOCK_ACCESS_FS_MAKE_BLOCK = 2048;
    LANDLOCK_ACCESS_FS_MAKE_SYM = 4096;
    LANDLOCK_RULE_PATH_BENEATH = 1;
}

# O_PATH and O_CLOEXEC for opening path references
enum PathFlag {
    O_PATH_FLAG = 0x200000;
    O_CLOEXEC_FLAG = 0x80000;
}

# Access level presets
enum SandboxAccess {
    SANDBOX_NO_ACCESS = 0;
    SANDBOX_READ_ONLY = 1;
    SANDBOX_READ_WRITE = 2;
    SANDBOX_READ_EXECUTE = 3;
}

# Sandbox rule: { path_ptr, access_level }
fn sandbox_rule_new(path, access) {
    var r = alloc(16);
    store64(r, path);
    store64(r + 8, access);
    return r;
}

fn sandbox_rule_path(r) { return load64(r); }
fn sandbox_rule_access(r) { return load64(r + 8); }

# Sandbox builder
fn sandbox_builder_new() {
    var b = alloc(16);
    store64(b, vec_new());
    store64(b + 8, 0);
    return b;
}

# Push a rule (path @ access level) onto the builder and bump the count.
# Shared body for the sandbox_allow_* presets below.
fn _sandbox_push(builder, path, access) {
    var v = load64(builder);
    vec_push(v, sandbox_rule_new(path, access));
    var c = load64(builder + 8);
    store64(builder + 8, c + 1);
    return 0;
}

fn sandbox_allow_read(builder, path) {
    return _sandbox_push(builder, path, SANDBOX_READ_ONLY);
}

fn sandbox_allow_read_write(builder, path) {
    return _sandbox_push(builder, path, SANDBOX_READ_WRITE);
}

fn sandbox_allow_read_exec(builder, path) {
    return _sandbox_push(builder, path, SANDBOX_READ_EXECUTE);
}

fn sandbox_rule_count(builder) {
    return load64(builder + 8);
}

# Convert access level to Landlock access flags
fn _access_to_flags(access) {
    switch (access) {
        case 1: return LANDLOCK_ACCESS_FS_READ_FILE | LANDLOCK_ACCESS_FS_READ_DIR;
        case 2: return LANDLOCK_ACCESS_FS_READ_FILE | LANDLOCK_ACCESS_FS_READ_DIR
        | LANDLOCK_ACCESS_FS_WRITE_FILE | LANDLOCK_ACCESS_FS_MAKE_REG;
        case 3: return LANDLOCK_ACCESS_FS_READ_FILE | LANDLOCK_ACCESS_FS_READ_DIR
        | LANDLOCK_ACCESS_FS_EXECUTE;
        default: return 0;
    }
}

# Handled access: every filesystem operation we control. Both
# sandbox_apply and sandbox_from_ruleset declare the ruleset over
# this full mask, so it lives here once.
fn _landlock_handled_mask() {
    return LANDLOCK_ACCESS_FS_EXECUTE | LANDLOCK_ACCESS_FS_WRITE_FILE
    | LANDLOCK_ACCESS_FS_READ_FILE | LANDLOCK_ACCESS_FS_READ_DIR
    | LANDLOCK_ACCESS_FS_REMOVE_DIR | LANDLOCK_ACCESS_FS_REMOVE_FILE
    | LANDLOCK_ACCESS_FS_MAKE_CHAR | LANDLOCK_ACCESS_FS_MAKE_DIR
    | LANDLOCK_ACCESS_FS_MAKE_REG | LANDLOCK_ACCESS_FS_MAKE_SOCK
    | LANDLOCK_ACCESS_FS_MAKE_FIFO | LANDLOCK_ACCESS_FS_MAKE_BLOCK
    | LANDLOCK_ACCESS_FS_MAKE_SYM;
}

# Create a Landlock ruleset over the full handled-access mask.
# Returns the ruleset fd, or a negative -errno on failure. Callers
# map ENOSYS(38)/EOPNOTSUPP(95) to the "kernel lacks Landlock" path.
fn _landlock_create_ruleset() {
    # LandlockRulesetAttr: { handled_access_fs: u64 } = 8 bytes
    var attr = alloc(8);
    store64(attr, _landlock_handled_mask());
    return syscall(SYS_LANDLOCK_CREATE_RULESET, attr, 8, 0);
}

# Add one PATH_BENEATH rule (path → allowed access mask) to ruleset_fd.
# Opens the path O_PATH, adds the rule, closes the path fd.
# Returns 0 on success, or a negative -errno on failure.
fn _landlock_add_path(ruleset_fd, path, allowed) {
    # sys_open() dispatches to openat(AT_FDCWD, ...) on aarch64
    # (no SYS_OPEN syscall on that arch). Direct `syscall(SYS_OPEN, ...)`
    # would fail to compile on `cyrius build --aarch64`.
    var path_fd = sys_open(path, O_PATH_FLAG | O_CLOEXEC_FLAG, 0);
    if (path_fd < 0) { return path_fd; }

    # LandlockPathBeneathAttr: { allowed_access: u64, parent_fd: i32 }
    var beneath = alloc(16);
    memset(beneath, 0, 16);
    store64(beneath, allowed);
    store32(beneath + 8, path_fd);

    var ret = syscall(SYS_LANDLOCK_ADD_RULE, ruleset_fd, LANDLOCK_RULE_PATH_BENEATH, beneath, 0);
    sys_close(path_fd);
    return ret;
}

# Apply Landlock restrictions from builder.
# Must be called after set_no_new_privs() (from privdrop.cyr).
# Returns: Result (Ok(0)=applied, Ok(1)=landlock unavailable, Err(errno))
fn sandbox_apply(builder) {
    var v = load64(builder);
    var count = load64(builder + 8);
    if (count == 0) { return Ok(0); }

    var ruleset_fd = _landlock_create_ruleset();
    if (ruleset_fd < 0) {
        var errno = 0 - ruleset_fd;
        # ENOSYS or EOPNOTSUPP = kernel doesn't support Landlock
        if (errno == 38) { return Ok(1); }
        if (errno == 95) { return Ok(1); }
        return Err(errno);
    }

    for (var idx = 0; idx < count; idx = idx + 1) {
        var rule = vec_get(v, idx);
        var path = sandbox_rule_path(rule);
        var access = sandbox_rule_access(rule);
        var allowed = _access_to_flags(access);

        if (allowed != 0) {
            var rc = _landlock_add_path(ruleset_fd, path, allowed);
            if (rc < 0) {
                sys_close(ruleset_fd);
                return Err(0 - rc);
            }
        }
    }

    var ret = syscall(SYS_LANDLOCK_RESTRICT_SELF, ruleset_fd, 0);
    sys_close(ruleset_fd);

    if (ret < 0) { return Err(0 - ret); }
    return Ok(0);
}

# ================================================================
# Agnostik integration
# ================================================================

# Convert agnostik LandlockFsAccess flags vec to kernel Landlock bitmask.
fn _ll_access_to_kernel(access_vec) {
    var mask = 0;
    var alen = vec_len(access_vec);
    for (var ai = 0; ai < alen; ai = ai + 1) {
        var flag = vec_get(access_vec, ai);
        # agnostik LL_ enums map 1:1 to kernel bit positions
        switch (flag) {
            case 0: mask = mask | LANDLOCK_ACCESS_FS_EXECUTE;
            case 1: mask = mask | LANDLOCK_ACCESS_FS_WRITE_FILE;
            case 2: mask = mask | LANDLOCK_ACCESS_FS_READ_FILE;
            case 3: mask = mask | LANDLOCK_ACCESS_FS_READ_DIR;
            case 4: mask = mask | LANDLOCK_ACCESS_FS_REMOVE_DIR;
            case 5: mask = mask | LANDLOCK_ACCESS_FS_REMOVE_FILE;
            case 6: mask = mask | LANDLOCK_ACCESS_FS_MAKE_CHAR;
            case 7: mask = mask | LANDLOCK_ACCESS_FS_MAKE_DIR;
            case 8: mask = mask | LANDLOCK_ACCESS_FS_MAKE_REG;
            case 9: mask = mask | LANDLOCK_ACCESS_FS_MAKE_SOCK;
            case 10: mask = mask | LANDLOCK_ACCESS_FS_MAKE_FIFO;
            case 11: mask = mask | LANDLOCK_ACCESS_FS_MAKE_BLOCK;
            case 12: mask = mask | LANDLOCK_ACCESS_FS_MAKE_SYM;
            default: return mask;
        }
    }
    return mask;
}

# Build a sandbox from an agnostik landlock_ruleset.
# Converts agnostik fs rules to kybernet sandbox rules and applies.
# Returns: Result (Ok(0)=applied, Ok(1)=landlock unavailable, Err(errno))
fn sandbox_from_ruleset(ruleset) {
    var fs_rules = llrs_fs_rules(ruleset);
    var rlen = vec_len(fs_rules);
    if (rlen == 0) { return Ok(0); }

    var ruleset_fd = _landlock_create_ruleset();
    if (ruleset_fd < 0) {
        var errno = 0 - ruleset_fd;
        if (errno == 38) { return Ok(1); }
        if (errno == 95) { return Ok(1); }
        return Err(errno);
    }

    for (var ri = 0; ri < rlen; ri = ri + 1) {
        var rule = vec_get(fs_rules, ri);
        var path = llfsr_path(rule);
        var access_vec = llfsr_allowed_access(rule);
        var allowed = _ll_access_to_kernel(access_vec);

        if (allowed != 0) {
            var rc = _landlock_add_path(ruleset_fd, path, allowed);
            if (rc < 0) {
                sys_close(ruleset_fd);
                return Err(0 - rc);
            }
        }
    }

    var ret = syscall(SYS_LANDLOCK_RESTRICT_SELF, ruleset_fd, 0);
    sys_close(ruleset_fd);
    if (ret < 0) { return Err(0 - ret); }
    return Ok(0);
}

# Build sandbox from agnostik sandbox_config.
# Extracts fs_rules, converts to filesystem_rule access levels, applies.
# Returns: Result
fn sandbox_from_config(config) {
    var fs_rules = sandbox_fs_rules(config);
    var rlen = vec_len(fs_rules);
    if (rlen == 0) { return Ok(0); }

    var b = sandbox_builder_new();
    for (var ri = 0; ri < rlen; ri = ri + 1) {
        var rule = vec_get(fs_rules, ri);
        var path = fsrule_path(rule);
        var access = fsrule_access(rule);
        switch (access) {
            case 0: return 0;
            case 1: sandbox_allow_read(b, path);
            case 2: sandbox_allow_read_write(b, path);
            default: return 0;
        }
    }
    return sandbox_apply(b);
}

# Create a basic service sandbox.
# Allows: read /usr, /lib, /etc; read-write /tmp, /var; exec /usr/bin, /usr/lib
fn sandbox_basic_service() {
    var b = sandbox_builder_new();
    sandbox_allow_read_exec(b, "/usr");
    sandbox_allow_read(b, "/lib");
    sandbox_allow_read(b, "/etc");
    sandbox_allow_read_write(b, "/tmp");
    sandbox_allow_read_write(b, "/var");
    sandbox_allow_read_write(b, "/run");
    return b;
}
