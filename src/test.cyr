# kybernet_test.cyr — integration test for upgraded kybernet modules
# Tests: Result returns, Option types, str_builder, callbacks

# Kybernet modules (stdlib + deps resolved via cyrius.toml)
include "src/lib/console.cyr"
include "src/lib/signals.cyr"
include "src/lib/reaper.cyr"
include "src/lib/privdrop.cyr"
include "src/lib/mount.cyr"
include "src/lib/cgroup.cyr"
include "src/lib/eventloop.cyr"
include "src/lib/notify.cyr"
include "src/lib/seccomp.cyr"
include "src/lib/sandbox.cyr"

fn test_constants() {
    println("--- constants ---");
    assert_eq(SYS_READ, 0, "SYS_READ");
    assert_eq(SYS_MOUNT, 165, "SYS_MOUNT");
    assert_eq(SIGCHLD, 17, "SIGCHLD");
    assert_eq(EPOLLIN, 1, "EPOLLIN");
    assert_eq(TOKEN_SIGNAL, 1, "TOKEN_SIGNAL");
    assert_eq(TOKEN_HEALTH, 2, "TOKEN_HEALTH");
    return 0;
}

fn test_process() {
    println("--- process ---");
    var pid = sys_getpid();
    assert(pid > 0, "getpid");
    var ppid = sys_getppid();
    assert(ppid > 0, "getppid");
    return 0;
}

fn test_wait_macros() {
    println("--- wait ---");
    assert(WIFEXITED(0) == 1, "WIFEXITED(0)");
    assert_eq(WEXITSTATUS(256), 1, "WEXITSTATUS(256)");
    assert(WIFSIGNALED(9) == 1, "WIFSIG(9)");
    assert_eq(WTERMSIG(9), 9, "WTERMSIG(9)");
    return 0;
}

fn test_signals() {
    println("--- signals ---");
    var set = sigset_new();
    sigset_add(set, SIGCHLD);
    sigset_add(set, SIGTERM);
    sigset_add(set, SIGPWR);
    assert(sigset_has(set, SIGCHLD) == 1, "has SIGCHLD");
    assert(sigset_has(set, SIGKILL) == 0, "!has SIGKILL");
    assert_eq(classify_signal(SIGCHLD), SIG_CLASS_CHILD, "class CHLD");
    assert_eq(classify_signal(SIGTERM), SIG_CLASS_TERM, "class TERM");
    assert_eq(classify_signal(99), SIG_CLASS_NONE, "class unknown");
    assert(is_handled_signal(SIGCHLD) == 1, "handled SIGCHLD");
    assert(is_handled_signal(SIGKILL) == 0, "!handled SIGKILL");
    return 0;
}

fn test_epoll() {
    println("--- epoll ---");
    var ev = epoll_event_new(EPOLLIN, 42);
    assert_eq(load32(ev), EPOLLIN, "ev events");
    assert_eq(load64(ev + 4), 42, "ev data");
    var ts = timerspec_new(10, 1);
    assert_eq(load64(ts), 10, "interval");

    # Live epoll test
    var epfd_r = epoll_new();
    assert(is_ok(epfd_r) == 1, "epoll_create");
    if (is_ok(epfd_r) == 1) {
        var epfd = result_unwrap(epfd_r);
        var tfd_r = timer_new(1);
        if (is_ok(tfd_r) == 1) {
            var r = epoll_add_read(epfd, result_unwrap(tfd_r), TOKEN_WATCHDOG);
            assert(is_ok(r) == 1, "epoll_add");
            sys_close(result_unwrap(tfd_r));
        }
        owned_fd_close(epfd);
    }
    return 0;
}

fn test_fileops() {
    println("--- fileops ---");
    var r = sys_mkdir("/tmp/cyr_ktest2", 0x1C0);
    assert(is_err(r) == 0, "mkdir");
    sys_rmdir("/tmp/cyr_ktest2");

    var fd = sys_open("/tmp/cyr_ktest2_f", O_WRONLY | O_CREAT | O_TRUNC, 0x1A4);
    assert(fd >= 0, "open");
    if (fd >= 0) {
        sys_write(fd, "test\n", 5);
        sys_close(fd);
        sys_unlink("/tmp/cyr_ktest2_f");
    }
    return 0;
}

fn test_cgroup() {
    println("--- cgroup ---");
    var path = cgroup_path("myservice");
    assert(str_contains(path, "kybernet.slice") == 1, "path has slice");
    assert(str_ends_with(path, "myservice") == 1, "path ends service");

    var file = cgroup_file("myservice", "cgroup.procs");
    assert(str_ends_with(file, "cgroup.procs") == 1, "file ends procs");
    return 0;
}

fn test_privdrop() {
    println("--- privdrop ---");
    var root = is_root();
    if (root == 0) {
        # Not root — verify drop_privileges returns NOT_ROOT
        var r = drop_privileges(1000, 1000);
        assert(is_err_result(r) == 1, "not root fails");
        assert_eq(payload(r), PRIV_NOT_ROOT, "PRIV_NOT_ROOT");
    } else {
        assert(root == 1, "is root");
    }
    return 0;
}

fn _dbl(x) { return x * 2; }
fn _sum(a, x) { return a + x; }

fn test_callbacks() {
    println("--- callbacks ---");
    var v = vec_new();
    vec_push(v, 1);
    vec_push(v, 2);
    vec_push(v, 3);
    var mapped = vec_map(v, &_dbl);
    assert_eq(vec_get(mapped, 0), 2, "map");
    assert_eq(vec_fold(v, 0, &_sum), 6, "fold");
    return 0;
}

fn test_knotify_classify() {
    println("--- notify ---");
    assert_eq(knotify_classify("READY=1"), NOTIFY_READY, "parse READY");
    assert_eq(knotify_classify("STOPPING=1"), NOTIFY_STOPPING, "parse STOPPING");
    assert_eq(knotify_classify("WATCHDOG=1"), NOTIFY_WATCHDOG, "parse WATCHDOG");
    assert_eq(knotify_classify("RELOADING=1"), NOTIFY_RELOADING, "parse RELOADING");
    assert_eq(knotify_classify("STATUS=running"), NOTIFY_STATUS, "parse STATUS");
    assert_eq(knotify_classify("UNKNOWN"), NOTIFY_UNKNOWN, "parse unknown");
    var sv = notify_status_value("STATUS=all good");
    assert(sv != 0, "status value ptr");
    assert(memeq(sv, "all good", 8) == 1, "status value content");
    var sv2 = notify_status_value("READY=1");
    assert_eq(sv2, 0, "non-status returns 0");
    return 0;
}

fn test_seccomp_builder() {
    println("--- seccomp ---");
    var b = seccomp_builder_new();
    assert_eq(seccomp_count(b), 0, "empty builder");
    seccomp_allow(b, 0);
    seccomp_allow(b, 1);
    seccomp_allow(b, 3);
    assert_eq(seccomp_count(b), 3, "3 allowed");

    # Build filter
    var info_r = seccomp_build(b);
    assert(is_ok(info_r) == 1, "build ok");
    if (is_ok(info_r) == 1) {
        var info = result_unwrap(info_r);
        var fptr = seccomp_filter_ptr(info);
        var flen = seccomp_filter_len(info);
        # 3 allowed + 3 fixed instructions = 6 instructions * 8 bytes = 48
        assert_eq(flen, 48, "filter size");
        assert(fptr != 0, "filter ptr");

        # Verify first instruction: BPF_LD_W_ABS
        assert_eq(load16(fptr), BPF_LD_W_ABS, "insn0 LD");
        # Verify last instruction: BPF_RET_K ALLOW
        assert_eq(load16(fptr + flen - 8), BPF_RET_K, "last insn RET");
        assert_eq(load32(fptr + flen - 4), SECCOMP_RET_ALLOW, "last insn ALLOW");
    }

    # Basic service builder has entries
    var bs = seccomp_basic_service();
    assert(seccomp_count(bs) > 20, "basic service syscalls");

    # Empty builder fails
    var empty = seccomp_builder_new();
    var er = seccomp_build(empty);
    assert(is_err_result(er) == 1, "empty build fails");
    return 0;
}

fn test_sandbox_builder() {
    println("--- sandbox ---");
    var b = sandbox_builder_new();
    assert_eq(sandbox_rule_count(b), 0, "empty sandbox");

    sandbox_allow_read(b, "/etc");
    sandbox_allow_read_write(b, "/tmp");
    sandbox_allow_read_exec(b, "/usr");
    assert_eq(sandbox_rule_count(b), 3, "3 rules");

    # Basic service builder
    var bs = sandbox_basic_service();
    assert(sandbox_rule_count(bs) >= 5, "basic svc rules");
    return 0;
}

fn test_caps() {
    println("--- capabilities ---");
    # Not root — drop_capabilities should fail with PRIV_NOT_ROOT
    if (is_root() == 0) {
        var r = drop_capabilities(0);
        assert(is_err_result(r) == 1, "caps need root");
        assert_eq(payload(r), PRIV_NOT_ROOT, "caps PRIV_NOT_ROOT");
    }

    # set_no_new_privs should work for any user
    var nnp = set_no_new_privs();
    assert(is_ok(nnp) == 1, "no_new_privs ok");

    # secure_pre_exec should fail for non-root when uid/gid given
    if (is_root() == 0) {
        var r2 = secure_pre_exec(1000, 1000, 0);
        assert(is_err_result(r2) == 1, "secure_pre_exec need root");
    }
    return 0;
}

fn test_agnostik_security() {
    println("--- agnostik security ---");

    # security_context_new
    var ctx = security_context_new("test-service");
    assert_eq(secctx_run_as_user(ctx), 0, "ctx uid default 0");
    assert_eq(secctx_run_as_group(ctx), 0, "ctx gid default 0");
    assert_eq(secctx_no_new_privs(ctx), 1, "ctx no_new_privs default 1");
    assert(secctx_sandbox(ctx) != 0, "ctx sandbox non-null");

    # sandbox_config_new
    var sbox = sandbox_config_new();
    assert_eq(sandbox_net_access(sbox), NET_LOCALHOST_ONLY, "sandbox net default localhost_only");
    assert_eq(sandbox_isolate_net(sbox), 1, "sandbox isolate_net default 1");

    # cgroup_limits_new
    var cg = cgroup_limits_new();
    assert_eq(cglim_memory_max(cg), 0, "cglim mem default 0");
    cglim_set_memory_max(cg, 268435456);
    assert_eq(cglim_memory_max(cg), 268435456, "cglim mem set 256MB");
    cglim_set_pids_max(cg, 64);
    assert_eq(cglim_pids_max(cg), 64, "cglim pids set 64");

    # capability_set_new
    var caps = capability_set_new();
    var bounding = capset_bounding(caps);
    assert_eq(vec_len(bounding), 0, "capset empty");
    vec_push(bounding, CAP_NET_BIND_SERVICE);
    vec_push(bounding, CAP_SYS_CHROOT);
    assert_eq(vec_len(capset_bounding(caps)), 2, "capset 2 caps");

    # namespace_config_new
    var ns = namespace_config_new();
    assert_eq(ns_pid(ns), 0, "ns pid default 0");
    ns_set_pid(ns, 1);
    assert_eq(ns_pid(ns), 1, "ns pid set 1");

    # resource_limits_new
    var rl = resource_limits_new();
    assert_eq(rlim_max_memory(rl), 268435456, "rlim default 256MB");
    assert_eq(rlim_max_fds(rl), 256, "rlim default 256 fds");
    assert_eq(rlim_max_procs(rl), 64, "rlim default 64 procs");

    # seccomp_profile_new
    var prof = seccomp_profile_new(SECCOMP_KILL_PROCESS);
    assert_eq(scprof_default_action(prof), SECCOMP_KILL_PROCESS, "scprof default kill");
    var rules = scprof_syscalls(prof);
    var rule = seccomp_rule_new(SECCOMP_ALLOW);
    var names = scrule_names(rule);
    vec_push(names, 0);
    vec_push(names, 1);
    vec_push(names, 3);
    vec_push(rules, rule);
    assert_eq(vec_len(scprof_syscalls(prof)), 1, "scprof 1 rule");

    # seccomp_from_profile integration
    var b = seccomp_from_profile(prof);
    assert_eq(seccomp_count(b), 3, "from_profile 3 syscalls");

    # landlock_ruleset_new
    var llrs = landlock_ruleset_new();
    var fs = llrs_fs_rules(llrs);
    var llr = landlock_fs_rule_new("/tmp");
    var acc = llfsr_allowed_access(llr);
    vec_push(acc, LL_READ_FILE);
    vec_push(acc, LL_READ_DIR);
    vec_push(fs, llr);
    assert_eq(vec_len(llrs_fs_rules(llrs)), 1, "llrs 1 fs rule");

    # filesystem_rule_new
    var fsr = filesystem_rule_new("/etc", FS_READ_ONLY);
    assert_eq(fsrule_access(fsr), FS_READ_ONLY, "fsrule read-only");
    assert_eq(fsrule_readonly(fsr), 0, "fsrule readonly default 0");

    # agnostik error types
    var err = agnostik_err_new(ERR_PERMISSION_DENIED, str_from("test"));
    assert_eq(agnostik_err_kind(err), ERR_PERMISSION_DENIED, "err kind");
    assert_eq(agnostik_err_code(err), CODE_PERMISSION_DENIED, "err code 1002");
    assert_eq(agnostik_err_is_retriable(err), 0, "perm denied not retriable");

    var terr = agnostik_err_new(ERR_TIMEOUT, 0);
    assert_eq(agnostik_err_is_retriable(terr), 1, "timeout retriable");

    return 0;
}

fn test_agnostik_agent() {
    println("--- agnostik agent ---");

    # agent_config_new
    var ac = agent_config_new("test-agent");
    assert_eq(aconf_type(ac), AGENT_TYPE_USER, "aconf default user type");
    assert_eq(aconf_restart_policy(ac), RESTART_NEVER, "aconf default no restart");
    assert(aconf_limits(ac) != 0, "aconf has limits");

    var limits = aconf_limits(ac);
    assert_eq(rlim_max_memory(limits), 268435456, "aconf limits 256MB");

    # Set sandbox
    var sbox = sandbox_config_new();
    sandbox_set_net_access(sbox, NET_LOCALHOST_ONLY);
    aconf_set_sandbox(ac, sbox);
    var got_sbox = aconf_sandbox(ac);
    assert_eq(sandbox_net_access(got_sbox), NET_LOCALHOST_ONLY, "aconf sandbox net");

    # health_check_new (argonaut 6-param version overrides agnostik default)
    # argonaut layout: {check_type, target, port, interval_ms, timeout_ms, retries}
    var hc = health_check_new(HC_TCP_CONNECT, 0, 8080, 30, 5, 3);
    assert_eq(load64(hc + 24), 30, "hc 30s interval");
    assert_eq(load64(hc + 32), 5, "hc 5s timeout");
    assert_eq(load64(hc + 40), 3, "hc 3 retries");

    return 0;
}

fn test_notify_constants() {
    println("--- notify constants ---");
    assert_eq(TOKEN_NOTIFY, 5, "TOKEN_NOTIFY");
    assert_eq(NOTIFY_READY, 1, "NOTIFY_READY");
    assert_eq(NOTIFY_STOPPING, 2, "NOTIFY_STOPPING");
    assert_eq(NOTIFY_WATCHDOG, 3, "NOTIFY_WATCHDOG");
    assert(notify_socket_path() != 0, "socket path");
    return 0;
}

fn test_mount_table() {
    println("--- mount table ---");
    # Verify mount table init doesn't crash (P(-1) fix: was buffer overflow)
    _init_mount_table();
    assert_eq(_mount_count, 6, "6 mount entries");

    # Verify is_mounted with /proc (should be mounted on test host)
    var r = is_mounted("/proc");
    assert_eq(r, 1, "proc is mounted");

    # Verify is_mounted with nonexistent path
    var r2 = is_mounted("/nonexistent_kybernet_test_mount");
    assert_eq(r2, 0, "nonexistent not mounted");

    # Verify is_mounted with empty target (P(-1) fix: underflow guard)
    var r3 = is_mounted("");
    assert_eq(r3, 0, "empty target not mounted");

    # Verify mount_if_needed returns Ok(1) for already-mounted
    var mr = mount_if_needed("proc", "/proc", "proc", 0, 0);
    assert(is_ok(mr) == 1, "mount_if_needed /proc ok");
    assert_eq(result_unwrap(mr), 1, "already mounted returns 1");
    return 0;
}

fn test_owned_fd() {
    println("--- owned_fd ---");
    # Create and close an OwnedFd
    var fd = sys_open("/dev/null", O_RDONLY, 0);
    assert(fd >= 0, "open /dev/null");
    var ofd = owned_fd_new(fd);
    assert_eq(owned_fd_raw(ofd), fd, "raw fd matches");
    owned_fd_close(ofd);
    assert_eq(owned_fd_raw(ofd), 0 - 1, "closed fd is -1");

    # Double-close should be safe (fd already -1)
    owned_fd_close(ofd);
    assert_eq(owned_fd_raw(ofd), 0 - 1, "double close safe");
    return 0;
}

fn test_eventloop_lifecycle() {
    println("--- eventloop lifecycle ---");
    # Full lifecycle: create epoll, add timer, close
    var epfd_r = epoll_new();
    assert(is_ok(epfd_r) == 1, "epoll create");
    var epfd = result_unwrap(epfd_r);

    # Add a timer
    var tfd_r = timer_new(1);
    assert(is_ok(tfd_r) == 1, "timer create");
    var tfd = result_unwrap(tfd_r);

    var add_r = epoll_add_read(epfd, tfd, TOKEN_HEALTH);
    assert(is_ok(add_r) == 1, "epoll add timer");

    # Add a second timer
    var tfd2_r = timer_new(5);
    assert(is_ok(tfd2_r) == 1, "timer2 create");
    var tfd2 = result_unwrap(tfd2_r);

    var add_r2 = epoll_add_read(epfd, tfd2, TOKEN_WATCHDOG);
    assert(is_ok(add_r2) == 1, "epoll add timer2");

    # Clean up
    sys_close(tfd);
    sys_close(tfd2);
    owned_fd_close(epfd);
    return 0;
}

fn test_eventloop_setup_full() {
    println("--- eventloop setup ---");
    # Test the full eventloop_setup function
    # Need a pollable fd — use a pipe read end
    var pipefd = alloc(16);
    var pr = sys_pipe(pipefd);
    assert(pr == 0, "pipe create");

    var read_fd = load32(pipefd);
    var write_fd = load32(pipefd + 4);

    var r = eventloop_setup(read_fd, 30, 10);
    assert(is_ok(r) == 1, "eventloop_setup ok");
    if (is_ok(r) == 1) {
        var epfd = result_unwrap(r);
        owned_fd_close(epfd);
    }
    sys_close(read_fd);
    sys_close(write_fd);
    return 0;
}

fn test_reaper_macros() {
    println("--- reaper ---");
    # Test wait status macros with various values
    # Normal exit with code 0
    assert_eq(WIFEXITED(0), 1, "exit(0) exited");
    assert_eq(WEXITSTATUS(0), 0, "exit(0) code 0");

    # Normal exit with code 42 (42 << 8 = 10752)
    assert_eq(WIFEXITED(10752), 1, "exit(42) exited");
    assert_eq(WEXITSTATUS(10752), 42, "exit(42) code");

    # Killed by signal 9 (SIGKILL)
    assert_eq(WIFSIGNALED(9), 1, "sig9 signaled");
    assert_eq(WTERMSIG(9), 9, "sig9 term sig");
    assert_eq(WIFEXITED(9), 0, "sig9 not exited");

    # Killed by signal 15 (SIGTERM)
    assert_eq(WIFSIGNALED(15), 1, "sig15 signaled");
    assert_eq(WTERMSIG(15), 15, "sig15 term sig");
    return 0;
}

fn test_signal_buffer() {
    println("--- signal buffer ---");
    # Verify the read_signal buffer is large enough (P(-1) fix)
    # We can't easily test signalfd reads without root,
    # but we can verify None is returned on invalid fd
    var r = read_signal(0 - 1);
    assert(is_none(r) == 1, "read_signal(-1) is None");
    return 0;
}

fn test_cgroup_extended() {
    println("--- cgroup extended ---");
    # Test various service names
    var p1 = cgroup_path("a");
    assert(str_ends_with(p1, "a") == 1, "single char svc");

    var p2 = cgroup_path("my-long-service-name");
    assert(str_contains(p2, "kybernet.slice") == 1, "long name has slice");
    assert(str_ends_with(p2, "my-long-service-name") == 1, "long name ends");

    # Test cgroup_file with different files
    var f1 = cgroup_file("svc", "memory.max");
    assert(str_ends_with(f1, "memory.max") == 1, "memory.max file");

    var f2 = cgroup_file("svc", "pids.max");
    assert(str_ends_with(f2, "pids.max") == 1, "pids.max file");
    return 0;
}

fn test_notify_edge_cases() {
    println("--- notify edge ---");
    # Empty message
    assert_eq(knotify_classify(""), NOTIFY_UNKNOWN, "empty msg");

    # Partial matches
    assert_eq(knotify_classify("READY"), NOTIFY_UNKNOWN, "READY without =1");
    assert_eq(knotify_classify("READY=0"), NOTIFY_UNKNOWN, "READY=0 not ready");
    assert_eq(knotify_classify("STATUS="), NOTIFY_STATUS, "STATUS= empty value");

    # Status value extraction
    var sv = notify_status_value("STATUS=");
    assert(sv != 0, "empty status has ptr");
    assert_eq(load8(sv), 0, "empty status is null-terminated");
    return 0;
}

fn test_seccomp_agnostik_bridge() {
    println("--- seccomp bridge ---");
    # Test seccomp_from_profile with multiple rules
    var prof = seccomp_profile_new(SECCOMP_KILL_PROCESS);
    var rules = scprof_syscalls(prof);

    # Rule 1: allow read/write/close
    var r1 = seccomp_rule_new(SECCOMP_ALLOW);
    var n1 = scrule_names(r1);
    vec_push(n1, SYS_READ);
    vec_push(n1, SYS_WRITE);
    vec_push(n1, SYS_CLOSE);
    vec_push(rules, r1);

    # Rule 2: allow exit
    var r2 = seccomp_rule_new(SECCOMP_ALLOW);
    var n2 = scrule_names(r2);
    vec_push(n2, 60);
    vec_push(rules, r2);

    var b = seccomp_from_profile(prof);
    assert_eq(seccomp_count(b), 4, "bridge merged 4 syscalls");

    var info_r = seccomp_build(b);
    assert(is_ok(info_r) == 1, "bridge build ok");
    return 0;
}

fn test_sandbox_rules() {
    println("--- sandbox rules ---");
    var b = sandbox_builder_new();

    # Add various rule types
    sandbox_allow_read(b, "/etc");
    sandbox_allow_read(b, "/usr/lib");
    sandbox_allow_read_write(b, "/tmp");
    sandbox_allow_read_write(b, "/var/run");
    sandbox_allow_read_exec(b, "/usr/bin");
    assert_eq(sandbox_rule_count(b), 5, "5 diverse rules");

    # Basic service preset should have standard paths
    var bs = sandbox_basic_service();
    assert(sandbox_rule_count(bs) >= 5, "basic has >= 5 rules");
    return 0;
}

fn main() {
    alloc_init();
    test_constants();
    test_process();
    test_wait_macros();
    test_signals();
    test_epoll();
    test_fileops();
    test_cgroup();
    test_privdrop();
    test_callbacks();
    test_knotify_classify();
    test_notify_constants();
    test_seccomp_builder();
    test_sandbox_builder();
    test_caps();
    test_agnostik_security();
    test_agnostik_agent();
    test_mount_table();
    test_owned_fd();
    test_eventloop_lifecycle();
    test_eventloop_setup_full();
    test_reaper_macros();
    test_signal_buffer();
    test_cgroup_extended();
    test_notify_edge_cases();
    test_seccomp_agnostik_bridge();
    test_sandbox_rules();
    return assert_summary();
}
var exit_code = main();
syscall(60, exit_code);
